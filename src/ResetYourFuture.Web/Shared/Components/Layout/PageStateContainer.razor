@* Handles the loading → error → empty → content state chain. *@

@if (IsLoading)
{
    @if (LoadingContent is not null)
    {
        @LoadingContent
    }
    else
    {
        <p>@LoadingText</p>
    }
}
else if (!string.IsNullOrEmpty(Error))
{
    <p class="text-danger">@Error</p>
}
else if (IsEmpty)
{
    @if (EmptyContent is not null)
    {
        @EmptyContent
    }
    else
    {
        <p>@EmptyText</p>
    }
}
else
{
    @ChildContent
}

@code {
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public string? Error { get; set; }
    [Parameter] public bool IsEmpty { get; set; }
    [Parameter] public string LoadingText { get; set; } = "Loading...";
    [Parameter] public string EmptyText { get; set; } = "No items found.";
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? EmptyContent { get; set; }
    [Parameter] public RenderFragment? LoadingContent { get; set; }
}
