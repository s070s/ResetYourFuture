@* Renders a dismissible Bootstrap alert. Renders nothing when Message is empty. *@

@if (!string.IsNullOrEmpty(Message))
{
    <div class="alert alert-@AlertType @(Dismissible ? "alert-dismissible" : "") mt-3">
        @Message
        @if (Dismissible)
        {
            <button type="button" class="btn-close" @onclick="OnDismiss"></button>
        }
    </div>
}

@code {
    [Parameter] public string Message { get; set; } = "";
    [Parameter] public string AlertType { get; set; } = "info";
    [Parameter] public EventCallback OnDismiss { get; set; }
    [Parameter] public bool Dismissible { get; set; } = true;
}
