@* Renders the main message area: header, pagination, message list, and input. *@

<div class="chat-main">
    @if ( Conversation is null )
    {
        <div class="chat-placeholder">
            <span class="bi bi-chat-dots" style="font-size: 3rem;"></span>
            <p>@ChatRes.SelectConversation</p>
        </div>
    }
    else
    {
        <div class="chat-header">
            @if (OnBackToList.HasDelegate)
            {
                <button class="btn-back-mobile" @onclick="OnBackToList" title="Back">
                    <span class="bi bi-arrow-left"></span>
                </button>
            }
            <h6>
                <span class="bi bi-person"></span> @Conversation.OtherUserName
                <span class="chat-header-role">(@Conversation.OtherUserRole)</span>
            </h6>
        </div>

        @if ( Messages is not null )
        {
            <div class="d-flex justify-content-between align-items-center px-3 py-1 chat-pagination">
                <small class="text-light-muted">@Messages.TotalCount messages</small>
                <div class="d-flex align-items-center gap-2">
                    <label class="form-label mb-0 text-light-muted small">Rows:</label>
                    <select class="page-size-select" value="@PageSize" @onchange="HandlePageSizeChange">
                        @foreach ( var opt in PageSizeOptions )
                        {
                            <option value="@opt">@opt</option>
                        }
                    </select>
                    <button class="btn btn-sm btn-outline-secondary"
                            @onclick="OnPreviousPage"
                            disabled="@(!Messages.HasPreviousPage)">‹ Older</button>
                    <span class="small">Page @Messages.Page of @Messages.TotalPages</span>
                    <button class="btn btn-sm btn-outline-secondary"
                            @onclick="OnNextPage"
                            disabled="@(!Messages.HasNextPage)">Newer ›</button>
                </div>
            </div>
        }

        <div class="chat-messages" @ref="_messageContainer">
            @if ( IsLoading )
            {
                <div class="text-center p-3">
                    <div class="spinner-border spinner-border-sm" role="status"></div>
                </div>
            }
            else
            {
                <Virtualize Items="Messages?.Items ?? new()" Context="msg" OverscanCount="10">
                    @{ var isMine = msg.SenderId == CurrentUserId; }
                    <div class="message-bubble @(isMine ? "mine" : "theirs")" @key="msg.Id">
                        <div class="message-sender">
                            @msg.SenderName
                            <span class="message-role">(@msg.SenderRole)</span>
                        </div>
                        <div class="message-content">@msg.Content</div>
                        <div class="message-time">@msg.SentAt.ToLocalTime().ToString( "HH:mm" )</div>
                    </div>
                </Virtualize>
            }
        </div>

        <div class="chat-input">
            <div class="textarea-wrapper">
                <div class="resize-handle-top" @ref="_resizeHandleRef"></div>
                <textarea class="form-control" placeholder="@ChatRes.TypeMessage"
                          rows="1"
                          @ref="_textareaRef"
                          @bind="_newMessage" @bind:event="oninput"
                          @onkeydown="HandleKeyDown"
                          disabled="@(!IsConnected)"></textarea>
            </div>
            <button class="btn btn-primary" @onclick="SendMessage"
                    disabled="@(string.IsNullOrWhiteSpace( _newMessage ) || !IsConnected)">
                <span class="bi bi-send"></span>
            </button>
        </div>
    }
</div>
