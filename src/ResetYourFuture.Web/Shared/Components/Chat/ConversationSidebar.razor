@* Renders the conversation list sidebar panel. *@

<div class="chat-sidebar">
    <div class="sidebar-header">
        <h5>@ChatRes.Conversations</h5>
        <button class="btn btn-sm btn-primary" @onclick="OnNewConversation"
                disabled="@IsStarting">
            <span class="bi bi-plus-circle"></span> @ChatRes.NewButton
        </button>
    </div>

    @if ( Conversations is null )
    {
        <div class="text-center p-3">
            <div class="spinner-border spinner-border-sm" role="status"></div>
        </div>
    }
    else if ( Conversations.Items.Count == 0 )
    {
        <div class="text-light-muted p-3 small">@ChatRes.NoConversations</div>
    }
    else
    {
        <div class="conversation-list" style="max-height:60vh; overflow-y:auto">
            <Virtualize Items="Conversations.Items" Context="convo" OverscanCount="10">
                @{ var isActive = SelectedConversationId == convo.Id; }
                <div class="conversation-item @(isActive ? "active" : "")"
                     @onclick="() => OnConversationSelected.InvokeAsync( convo )"
                     @key="convo.Id">
                    <div class="convo-name">
                        @convo.OtherUserName
                        <span class="convo-role">@convo.OtherUserRole</span>
                    </div>
                    <div class="convo-preview">@( convo.LastMessageContent ?? ChatRes.NoMessages )</div>
                    @if ( convo.UnreadCount > 0 )
                    {
                        <span class="badge bg-danger">@convo.UnreadCount</span>
                    }
                    <button class="btn btn-sm convo-delete-btn"
                            @onclick:stopPropagation="true"
                            @onclick="() => OnDeleteRequested.InvokeAsync( convo )"
                            title="@ChatRes.DeleteConversation">
                        <span class="bi bi-trash"></span>
                    </button>
                </div>
            </Virtualize>
        </div>
        <div class="d-flex justify-content-between align-items-center px-2 py-1 sidebar-pagination">
            <small class="text-light-muted">@Conversations.TotalCount</small>
            <div class="d-flex align-items-center gap-1">
                <label class="form-label mb-0 text-light-muted small">Rows:</label>
                <select class="page-size-select" value="@PageSize" @onchange="HandlePageSizeChange">
                    @foreach ( var opt in PageSizeOptions )
                    {
                        <option value="@opt">@opt</option>
                    }
                </select>
                <button class="btn btn-sm btn-outline-secondary"
                        @onclick="OnPreviousPage"
                        disabled="@(!Conversations.HasPreviousPage)">‹</button>
                <span class="small">@Conversations.Page/@Conversations.TotalPages</span>
                <button class="btn btn-sm btn-outline-secondary"
                        @onclick="OnNextPage"
                        disabled="@(!Conversations.HasNextPage)">›</button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public PagedResult<ChatConversationDto>? Conversations { get; set; }
    [Parameter] public Guid? SelectedConversationId { get; set; }
    [Parameter] public bool IsStarting { get; set; }
    [Parameter, EditorRequired] public int PageSize { get; set; }
    [Parameter, EditorRequired] public int[] PageSizeOptions { get; set; } = [];
    [Parameter, EditorRequired] public EventCallback OnNewConversation { get; set; }
    [Parameter, EditorRequired] public EventCallback<ChatConversationDto> OnConversationSelected { get; set; }
    [Parameter, EditorRequired] public EventCallback<ChatConversationDto> OnDeleteRequested { get; set; }
    [Parameter, EditorRequired] public EventCallback<int> OnPageSizeChanged { get; set; }
    [Parameter, EditorRequired] public EventCallback OnPreviousPage { get; set; }
    [Parameter, EditorRequired] public EventCallback OnNextPage { get; set; }

    private async Task HandlePageSizeChange( ChangeEventArgs e )
    {
        if ( int.TryParse( e.Value?.ToString() , out var size ) )
            await OnPageSizeChanged.InvokeAsync( size );
    }
}
