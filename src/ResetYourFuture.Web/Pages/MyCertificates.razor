@page "/my-certificates"
@attribute [Authorize(Roles = "Student")]

<PageTitle>My Certificates</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">My Certificates</h3>
</div>

@if (_loading)
{
    <p>Loading certificates…</p>
}
else if (_certificates is null || _certificates.Count == 0)
{
    <div class="alert alert-info">
        No certificates yet. Complete a course to earn one.
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var cert in _certificates)
        {
            <div class="col-md-6 col-lg-4" @key="cert.Id">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">@cert.CourseTitle</h5>
                        <p class="card-text text-light-muted small mb-1">
                            Issued: @cert.IssuedAt.ToString("MMMM dd, yyyy")
                        </p>
                        <p class="card-text">
                            <small class="text-light-muted">ID: @cert.VerificationId</small>
                        </p>
                    </div>
                    <div class="card-footer d-flex gap-2 flex-wrap">
                        <button class="btn btn-sm btn-primary"
                                disabled="@(_downloading == cert.Id)"
                                @onclick="() => DownloadAsync(cert)">
                            @if (_downloading == cert.Id)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            }
                            else
                            {
                                <span class="bi bi-download me-1" aria-hidden="true"></span>
                            }
                            Download PDF
                        </button>
                        <a class="btn btn-sm btn-outline-secondary"
                           href="certificate/@cert.VerificationId"
                           target="_blank"
                           rel="noopener noreferrer">
                            <span class="bi bi-shield-check me-1" aria-hidden="true"></span>
                            Verify
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}

<DismissibleAlert Message="@_error" AlertType="danger" OnDismiss="@(() => _error = string.Empty)" />
