@page "/chat"
@attribute [Authorize]
@implements IAsyncDisposable

<PageTitle>@ChatRes.PageTitle</PageTitle>

@if ( !_accessChecked )
{
    <div class="text-center p-5">
        <div class="spinner-border" role="status"></div>
    </div>
}
else if ( !_chatAccess )
{
    <UpgradePrompt PlanName="Pro"
                   FeatureName="Chat"
                   Description="@ChatRes.UpgradeDescription" />
}
else
{
    <div class="chat-container @(_selectedConversation is not null ? "conversation-active" : "")">
        <ConversationSidebar Conversations="_conversations"
                             SelectedConversationId="_selectedConversation?.Id"
                             IsStarting="_isStarting"
                             PageSize="_conversationsPageSize"
                             PageSizeOptions="ConversationPageSizeOptions"
                             OnNewConversation="OpenUserPicker"
                             OnConversationSelected="SelectConversation"
                             OnDeleteRequested="ConfirmDeleteConversation"
                             OnPageSizeChanged="OnConversationPageSizeChanged"
                             OnPreviousPage="PreviousConversationPage"
                             OnNextPage="NextConversationPage" />

        <MessagePane Conversation="_selectedConversation"
                     Messages="_pagedMessages"
                     CurrentUserId="_currentUserId"
                     IsLoading="_isLoadingMessages"
                     IsConnected="ChatService.IsConnected"
                     PageSize="_messagesPageSize"
                     PageSizeOptions="MessagePageSizeOptions"
                     OnSendMessage="HandleSendMessage"
                     OnBackToList="HandleBackToList"
                     OnPageSizeChanged="OnMessagePageSizeChanged"
                     OnPreviousPage="PreviousMessagePage"
                     OnNextPage="NextMessagePage" />
    </div>
}

<UserPickerModal IsVisible="_showUserPicker"
                 OnClose="CloseUserPicker"
                 OnUserPicked="HandleUserPicked" />

<ConfirmModal IsVisible="@(_conversationToDelete is not null)"
              Title="@ChatRes.DeleteConversation"
              ConfirmLabel="@ChatRes.Delete"
              CancelLabel="@ChatRes.Cancel"
              IsBusy="_isDeleting"
              OnConfirm="ExecuteDeleteConversationAsync"
              OnCancel="CancelDeleteConversation">
    <BodyContent>
        <p>@ChatRes.DeleteConfirm</p>
        <p class="fw-semibold mb-0">@_conversationToDelete?.OtherUserName</p>
    </BodyContent>
</ConfirmModal>
