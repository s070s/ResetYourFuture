@page "/subscription/success"
@attribute [Authorize]

<PageTitle>@SubscriptionSuccessRes.PageTitle</PageTitle>

<div class="success-page">
    @if (_loading)
    {
        <p>@SubscriptionSuccessRes.LoadingSubscription</p>
    }
    else if (_status is not null)
    {
        <div class="success-card">
            <div class="success-icon">🎉</div>
            <h1>@string.Format(SubscriptionSuccessRes.PlanHeadingFormat, _status.PlanName)</h1>
            <p>@SubscriptionSuccessRes.SubscriptionActive</p>

            <div class="plan-details">
                <p><strong>@SubscriptionSuccessRes.LabelPlan</strong> @_status.PlanName</p>
                <p><strong>@SubscriptionSuccessRes.LabelStarted</strong> @_status.StartedAt.ToString("dd MMM yyyy")</p>
                @if (_status.ExpiresAt.HasValue)
                {
                    <p><strong>@SubscriptionSuccessRes.LabelRenews</strong> @_status.ExpiresAt.Value.ToString("dd MMM yyyy")</p>
                }
            </div>

            <div class="success-actions">
                <button class="btn btn-primary" @onclick="GoToCourses">@SubscriptionSuccessRes.BtnBrowseCourses</button>
                <button class="btn btn-secondary" @onclick="GoToPricing">@SubscriptionSuccessRes.BtnViewPlans</button>
            </div>
        </div>
    }
    else
    {
        <p>@SubscriptionSuccessRes.UnableToLoad</p>
        <button class="btn btn-secondary" @onclick="GoToPricing">@SubscriptionSuccessRes.BtnBackToPricing</button>
    }
</div>
 

