@page "/forgot-password"

<PageTitle>@GlobalRes.ForgotPasswordTitle</PageTitle>

<div class="auth-container">
    <h2>@GlobalRes.ForgotPasswordTitle</h2>

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success">
            @successMessage
            <div class="mt-3">
                <p><strong>@GlobalRes.Label_DevMode</strong> Reset password directly</p>
                <input type="password" class="form-control mb-2" @bind="devNewPassword" placeholder="@GlobalRes.Label_NewPassword" />
                <button class="btn btn-sm btn-warning" @onclick="DevResetPassword">@GlobalRes.Label_DevResetPassword</button>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    @if (string.IsNullOrEmpty(successMessage))
    {
        <p>@GlobalRes.ForgotPasswordInstructions</p>

        <EditForm Model="@forgotPasswordRequest" OnValidSubmit="HandleSubmit">
            <div class="mb-3">
                <label for="email" class="form-label">@GlobalRes.Label_Info_Email</label>
                <input type="email" id="email" class="form-control" @bind="forgotPasswordRequest.Email" required />
            </div>

            <button type="submit" class="btn btn-primary" disabled="@isLoading">
                @if (isLoading) { <span>@GlobalRes.Label_Sending</span> } else { <span>@GlobalRes.Label_SendResetLink</span> }
            </button>
        </EditForm>
    }

    <p class="mt-3">
        <a href="/login">@ErrorMessagesRes.BackToLogin</a>
    </p>
</div>

