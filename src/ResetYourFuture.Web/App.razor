@inject IHttpContextAccessor HttpContextAccessor
@{
    var cultureFeature = HttpContextAccessor.HttpContext?.Features
        .Get<Microsoft.AspNetCore.Localization.IRequestCultureFeature>();
    var htmlLang = cultureFeature?.RequestCulture.UICulture.TwoLetterISOLanguageName ?? "en";
}
<!DOCTYPE html>
<html lang="@htmlLang">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Your Future</title>
    <base href="/" />
    <HeadOutlet />

    <!-- Preconnect hints -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />

    <!-- Critical CSS (needed for first paint) -->
    <link rel="stylesheet" href="lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="css/app.css" />
    <link rel="stylesheet" href="css/shared-components.css" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <link href="ResetYourFuture.Web.styles.css" rel="stylesheet" />

    <!-- Non-critical CSS deferred until after first paint -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
          media="print" onload="this.media='all'" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
          integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
          crossorigin="anonymous" referrerpolicy="no-referrer"
          media="print" onload="this.media='all'" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css"
          media="print" onload="this.media='all'" />
</head>

<body>
    @* prerender: false eliminates the double OnInitializedAsync (SSR pre-render + circuit reconnect)
       that causes visible page flicker and duplicate API calls on every navigation. *@
    <Routes @rendermode="@(new InteractiveServerRenderMode(prerender: true))" />

    <div id="blazor-error-ui" data-nosnippet>
        An unhandled error has occurred.
        <a href="." class="reload">Reload</a>
        <span class="dismiss">&#x2715;</span>
    </div>

    <!-- Defer heavy third-party JS -->
    <script defer src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"></script>
    <script defer src="js/quill-interop.js"></script>
    <script defer src="js/chat-interop.js"></script>
    <script defer src="js/cert-interop.js"></script>
    <script src="_framework/blazor.web.js"></script>
</body>

</html>
