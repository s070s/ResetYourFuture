<nav class="navbar navbar-expand-md navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Reset Your Future</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="@NavMenuCssClass navbar-collapse" @onclick="ToggleNavMenu">
            <ul class="navbar-nav me-auto">

                <AuthorizeView>
                    <Authorized>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="profile">
                                <span class="bi bi-person" aria-hidden="true"></span> @NavMenuRes.Profile
                            </NavLink>
                        </li>
                    </Authorized>
                    <NotAuthorized>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                                <span class="bi bi-house" aria-hidden="true"></span> @NavMenuRes.Home
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="login">
                                <span class="bi bi-box-arrow-in-right" aria-hidden="true"></span> @NavMenuRes.Login
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="register">
                                <span class="bi bi-person-add" aria-hidden="true"></span> @NavMenuRes.Register
                            </NavLink>
                        </li>
                    </NotAuthorized>
                </AuthorizeView>

                <AuthorizeView Roles="Student">
                    <li class="nav-item">
                        <NavLink class="nav-link" href="courses">
                            <span class="bi bi-book" aria-hidden="true"></span> @NavMenuRes.Courses
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="assessments">
                            <span class="bi bi-list-check" aria-hidden="true"></span> @NavMenuRes.Assessments
                        </NavLink>
                    </li>
                </AuthorizeView>

                <AuthorizeView Roles="Admin">
                    <li class="nav-item">
                        <NavLink class="nav-link" href="admin/users">
                            <span class="bi bi-people" aria-hidden="true"></span> @NavMenuRes.Users
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="admin/courses">
                            <span class="bi bi-book" aria-hidden="true"></span> @NavMenuRes.Courses
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="admin/assessments">
                            <span class="bi bi-list-check" aria-hidden="true"></span> @NavMenuRes.Assessments
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="admin/analytics">
                            <span class="bi bi-bar-chart" aria-hidden="true"></span> @NavMenuRes.Analytics
                        </NavLink>
                    </li>
                </AuthorizeView>
            </ul>
        </div>
    </div>
</nav>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
