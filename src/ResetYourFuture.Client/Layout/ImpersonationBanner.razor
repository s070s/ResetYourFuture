@implements IDisposable

@if (_isImpersonating)
{
    <div class="impersonation-banner d-flex align-items-center justify-content-between px-4 py-2">
        <span>
            <strong>👁 Admin view:</strong> logged in as <strong>@_impersonatedName</strong> (@_impersonatedEmail)
        </span>
        <button class="btn btn-sm btn-light fw-semibold" @onclick="ExitAsync">
            ✕ Exit Impersonation
        </button>
    </div>
}

