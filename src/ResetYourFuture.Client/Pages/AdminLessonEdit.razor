@page "/admin/lessons/{ModuleId:guid}"
@using ResetYourFuture.Client.Shared
@attribute [Authorize(Roles = "Admin")]

<PageTitle>@AdminRes.ManageLessons</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@AdminRes.ManageLessons</h2>
    <button class="btn btn-secondary" @onclick="GoBack">@AdminRes.BackToCourse</button>
</div>

<div class="mb-3">
    <button class="btn btn-success" @onclick="ShowAddLesson">@AdminRes.AddLesson</button>
</div>

@if (lessons == null)
{
    <p>@AdminRes.Loading</p>
}
else if (lessons.Count == 0)
{
    <p class="text-light-muted">@AdminRes.NoLessons</p>
}
else
{
    <div class="list-group">
        @foreach (var lesson in lessons.OrderBy(l => l.SortOrder))
        {
            <div class="list-group-item" @key="lesson.Id">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-1">@lesson.TitleEn</h6>
                        <small class="text-light-muted">
                            @string.Format(AdminRes.OrderFormat, lesson.SortOrder)
                            @if (lesson.DurationMinutes.HasValue)
                            {
                                <text>@string.Format(AdminRes.MinutesFormat, lesson.DurationMinutes)</text>
                            }
                            @if (lesson.IsPublished)
                            {
                                <span class="badge bg-success ms-1">@AdminRes.StatusPublished</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary ms-1">@AdminRes.StatusDraft</span>
                            }
                        </small>
                    </div>
                    <div>
                        <button class="btn btn-sm btn-primary" @onclick="() => ShowEditLesson(lesson)">@AdminRes.Edit</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteLesson(lesson.Id)">@AdminRes.Delete</button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@* Lesson Create/Edit Modal *@
@if (showLessonModal)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editingLessonId == null ? AdminRes.AddLesson : AdminRes.EditLesson)</h5>
                    <button type="button" class="btn-close" @onclick="CloseLessonModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-3 mb-3">
                            <label class="form-label">@AdminRes.FieldTitle (EN)</label>
                            <input class="form-control" @bind="lessonTitleEn" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">@AdminRes.FieldTitle (EL)</label>
                            <input class="form-control" @bind="lessonTitleEl" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">@AdminRes.SortOrder</label>
                            <input type="number" class="form-control" @bind="lessonSortOrder" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">@AdminRes.DurationMinutes</label>
                            <input type="number" class="form-control" @bind="lessonDuration" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">@AdminRes.FieldContent (EN)</label>
                        <QuillEditor @ref="lessonContentEditorEn" Content="@lessonContentEn" MinHeight="300px" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">@AdminRes.FieldContent (EL)</label>
                        <QuillEditor @ref="lessonContentEditorEl" Content="@lessonContentEl" MinHeight="300px" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">@AdminRes.VideoUrlLabel</label>
                        <input class="form-control" @bind="lessonVideoUrl" placeholder="https://www.youtube.com/embed/..." />
                        <small class="text-light-muted">@AdminRes.VideoUrlHint</small>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">@AdminRes.UploadPdf</label>
                            <InputFile class="form-control" OnChange="OnPdfSelected" accept=".pdf" />
                            @if (!string.IsNullOrEmpty(lessonPdfPath))
                            {
                                <small class="text-success">@AdminRes.Current @lessonPdfPath</small>
                            }
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">@AdminRes.UploadVideo</label>
                            <InputFile class="form-control" OnChange="OnVideoSelected" accept="video/*" />
                            @if (!string.IsNullOrEmpty(lessonVideoPath))
                            {
                                <small class="text-success">@AdminRes.Current @lessonVideoPath</small>
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-primary" @onclick="SaveLesson" disabled="@isSaving">
                        @(isSaving ? AdminRes.Saving : AdminRes.SaveLesson)
                    </button>
                    <button class="btn btn-secondary" @onclick="CloseLessonModal">@AdminRes.Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-info alert-dismissible mt-3">
        @message
        <button type="button" class="btn-close" @onclick="() => message = string.Empty"></button>
    </div>
}

