@page "/admin/lessons/{ModuleId:guid}"
@using ResetYourFuture.Client.Shared
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Manage Lessons</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Manage Lessons</h2>
    <button class="btn btn-secondary" @onclick="GoBack">← Back to Course</button>
</div>

<div class="mb-3">
    <button class="btn btn-success" @onclick="ShowAddLesson">+ Add Lesson</button>
</div>

@if (lessons == null)
{
    <p>Loading...</p>
}
else if (lessons.Count == 0)
{
    <p class="text-muted">No lessons in this module yet.</p>
}
else
{
    <div class="list-group">
        @foreach (var lesson in lessons.OrderBy(l => l.SortOrder))
        {
            <div class="list-group-item" @key="lesson.Id">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-1">@lesson.Title</h6>
                        <small class="text-muted">
                            Order: @lesson.SortOrder
                            @if (lesson.DurationMinutes.HasValue)
                            {
                                <text> · @lesson.DurationMinutes min</text>
                            }
                            @if (lesson.IsPublished)
                            {
                                <span class="badge bg-success ms-1">Published</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary ms-1">Draft</span>
                            }
                        </small>
                    </div>
                    <div>
                        <button class="btn btn-sm btn-primary" @onclick="() => ShowEditLesson(lesson)">Edit</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteLesson(lesson.Id)">Delete</button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@* Lesson Create/Edit Modal *@
@if (showLessonModal)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editingLessonId == null ? "Add Lesson" : "Edit Lesson")</h5>
                    <button type="button" class="btn-close" @onclick="CloseLessonModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Title</label>
                            <input class="form-control" @bind="lessonTitle" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Sort Order</label>
                            <input type="number" class="form-control" @bind="lessonSortOrder" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Duration (minutes)</label>
                            <input type="number" class="form-control" @bind="lessonDuration" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Content</label>
                        <QuillEditor @ref="lessonContentEditor" Content="@lessonContent" MinHeight="300px" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Video URL (YouTube embed or direct link)</label>
                        <input class="form-control" @bind="lessonVideoUrl" placeholder="https://www.youtube.com/embed/..." />
                        <small class="text-muted">Paste a YouTube embed URL or direct video link. This takes priority over uploaded files.</small>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Upload PDF</label>
                            <InputFile class="form-control" OnChange="OnPdfSelected" accept=".pdf" />
                            @if (!string.IsNullOrEmpty(lessonPdfPath))
                            {
                                <small class="text-success">Current: @lessonPdfPath</small>
                            }
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Upload Video File</label>
                            <InputFile class="form-control" OnChange="OnVideoSelected" accept="video/*" />
                            @if (!string.IsNullOrEmpty(lessonVideoPath))
                            {
                                <small class="text-success">Current: @lessonVideoPath</small>
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-primary" @onclick="SaveLesson" disabled="@isSaving">
                        @(isSaving ? "Saving..." : "Save Lesson")
                    </button>
                    <button class="btn btn-secondary" @onclick="CloseLessonModal">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-info alert-dismissible mt-3">
        @message
        <button type="button" class="btn-close" @onclick="() => message = string.Empty"></button>
    </div>
}

