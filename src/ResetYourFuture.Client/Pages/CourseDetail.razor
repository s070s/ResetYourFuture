@page "/courses/{CourseId:guid}"
@attribute [Authorize]

<PageTitle>@(_course?.Title ?? "Course") - Reset Your Future</PageTitle>

@if (_loading)
{
    <p>Loading course...</p>
}
else if (_error is not null)
{
    <p class="text-danger">@_error</p>
    <button class="btn btn-secondary" @onclick="GoBack">← Back to Courses</button>
}
else if (_course is null)
{
    <p>Course not found.</p>
    <button class="btn btn-secondary" @onclick="GoBack">← Back to Courses</button>
}
else
{
    <div class="course-header">
        <button class="btn-link" @onclick="GoBack">← Back to Courses</button>
        <h1>@_course.Title</h1>
        @if (!string.IsNullOrEmpty(_course.Description))
        {
            <p class="description">@_course.Description</p>
        }

        <div class="progress-section">
            @if (_course.IsEnrolled)
            {
                <div class="progress-bar-container">
                    <div class="progress-bar-fill" style="width: @(_course.ProgressPercent)%"></div>
                </div>
                <span class="progress-text">
                    @_course.CompletedLessons / @_course.TotalLessons lessons completed (@_course.ProgressPercent%)
                </span>
                @if (_course.IsCompleted)
                {
                    <span class="completed-badge">🎉 Course Completed!</span>
                }
            }
            else
            {
                <button class="btn btn-primary" @onclick="EnrollInCourse" disabled="@_enrolling">
                    @(_enrolling ? "Enrolling..." : "Enroll in This Course")
                </button>
            }
        </div>
    </div>

    <div class="modules-list">
        @foreach (var module in _course.Modules.OrderBy(m => m.SortOrder))
        {
            <div class="module-card">
                <h3>@module.SortOrder. @module.Title</h3>
                @if (!string.IsNullOrEmpty(module.Description))
                {
                    <p class="module-description">@module.Description</p>
                }

                <ul class="lessons-list">
                    @foreach (var lesson in module.Lessons.OrderBy(l => l.SortOrder))
                    {
                        <li class="lesson-item @(lesson.IsCompleted ? "completed" : "")" 
                            @onclick="() => ViewLesson(lesson.Id)">
                            <span class="lesson-icon">
                                @if (lesson.IsCompleted)
                                {
                                    <text>✓</text>
                                }
                                else if (lesson.ContentType == 2)
                                {
                                    <text>▶</text>
                                }
                                else
                                {
                                    <text>📄</text>
                                }
                            </span>
                            <span class="lesson-title">@lesson.Title</span>
                            @if (lesson.DurationMinutes.HasValue)
                            {
                                <span class="lesson-duration">@lesson.DurationMinutes min</span>
                            }
                        </li>
                    }
                </ul>
            </div>
        }
    </div>
}

<style>
    .course-header {
        margin-bottom: 2rem;
    }

    .course-header h1 {
        margin: 0.5rem 0;
    }

    .course-header .description {
        color: #666;
        font-size: 1.1rem;
    }

    .btn-link {
        background: none;
        border: none;
        color: #007bff;
        cursor: pointer;
        padding: 0;
        font-size: 0.9rem;
    }

    .btn-link:hover {
        text-decoration: underline;
    }

    .progress-section {
        margin-top: 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .progress-bar-container {
        width: 100%;
        max-width: 400px;
        height: 8px;
        background: #e0e0e0;
        border-radius: 4px;
        overflow: hidden;
    }

    .progress-bar-fill {
        height: 100%;
        background: #28a745;
        transition: width 0.3s;
    }

    .progress-text {
        font-size: 0.9rem;
        color: #666;
    }

    .completed-badge {
        color: #28a745;
        font-weight: bold;
    }

    .modules-list {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .module-card {
        border: 1px solid #ddd;
        border-radius: 8px;
        padding: 1.5rem;
    }

    .module-card h3 {
        margin: 0 0 0.5rem 0;
    }

    .module-description {
        color: #666;
        margin-bottom: 1rem;
    }

    .lessons-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .lesson-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem;
        border-radius: 4px;
        cursor: pointer;
        transition: background 0.2s;
    }

    .lesson-item:hover {
        background: #f5f5f5;
    }

    .lesson-item.completed {
        color: #28a745;
    }

    .lesson-icon {
        width: 24px;
        text-align: center;
    }

    .lesson-title {
        flex: 1;
    }

    .lesson-duration {
        color: #888;
        font-size: 0.85rem;
    }

    .btn-primary {
        background: #007bff;
        color: white;
        border: none;
        padding: 0.75rem 1.5rem;
        border-radius: 4px;
        cursor: pointer;
        font-size: 1rem;
    }

    .btn-primary:hover {
        background: #0056b3;
    }

    .btn-primary:disabled {
        background: #ccc;
        cursor: not-allowed;
    }
</style>

