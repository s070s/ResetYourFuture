@page "/courses/{CourseId:guid}"
@attribute [Authorize]

<PageTitle>@(_course?.Title ?? CourseRes.CourseDefault) - Reset Your Future</PageTitle>

@if (_loading)
{
    <p>@CourseRes.LoadingCourse</p>
}
else if (_error is not null)
{
    <p class="text-danger">@_error</p>
    <button class="btn btn-secondary" @onclick="GoBack">@CourseRes.BackToCourses</button>
}
else if (_course is null)
{
    <p>@CourseRes.CourseNotFound</p>
    <button class="btn btn-secondary" @onclick="GoBack">@CourseRes.BackToCourses</button>
}
else
{
    <div class="course-header">
        <button class="btn-link" @onclick="GoBack">@CourseRes.BackToCourses</button>
        <h1>@_course.Title</h1>
        @if (!string.IsNullOrEmpty(_course.Description))
        {
            <p class="description">@_course.Description</p>
        }

        <div class="progress-section">
            @if (_course.IsEnrolled)
            {
                <div class="progress-bar-container">
                    <div class="progress-bar-fill" style="width: @(_course.ProgressPercent)%"></div>
                </div>
                <span class="progress-text">
                    @string.Format(CourseRes.ProgressFormat, _course.CompletedLessons, _course.TotalLessons, _course.ProgressPercent)
                </span>
                @if (_course.IsCompleted)
                {
                    <span class="completed-badge">@CourseRes.CourseCompleted</span>
                }
            }
            else
            {
                <button class="btn btn-primary" @onclick="EnrollInCourse" disabled="@_enrolling">
                    @(_enrolling ? CourseRes.Enrolling : CourseRes.EnrollInThisCourse)
                </button>
            }
        </div>
    </div>

    <div class="modules-list">
        @foreach (var module in _course.Modules.OrderBy(m => m.SortOrder))
        {
            <div class="module-card">
                <h3>@module.SortOrder. @module.Title</h3>
                @if (!string.IsNullOrEmpty(module.Description))
                {
                    <p class="module-description">@module.Description</p>
                }

                <ul class="lessons-list">
                    @foreach (var lesson in module.Lessons.OrderBy(l => l.SortOrder))
                    {
                        <li class="lesson-item @(lesson.IsCompleted ? "completed" : "")" 
                            @onclick="() => ViewLesson(lesson.Id)">
                            <span class="lesson-icon">
                                @if (lesson.IsCompleted)
                                {
                                    <text>✓</text>
                                }
                                else if (lesson.ContentType == 2)
                                {
                                    <text>▶</text>
                                }
                                else
                                {
                                    <text>📄</text>
                                }
                            </span>
                            <span class="lesson-title">@lesson.Title</span>
                            @if (lesson.DurationMinutes.HasValue)
                            {
                                <span class="lesson-duration">@lesson.DurationMinutes @CourseRes.MinutesShort</span>
                            }
                        </li>
                    }
                </ul>
            </div>
        }
    </div>
}

