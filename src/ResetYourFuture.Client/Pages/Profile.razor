@page "/profile"
@attribute [Authorize]
@inject HttpClient Http
@inject IAuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Profile</PageTitle>

<div class="profile-container">
    <h2>My Profile</h2>

    <AuthorizeView>
        <Authorized>
            @if (userInfo == null)
            {
                <p>Loading...</p>
            }
            else
            {
                <div class="card mb-3">
                    <div class="card-body">
                        <h5>Basic Information</h5>
                        <div class="mb-3">
                            <label class="form-label">Avatar</label>
                            <div>
                                @if (!string.IsNullOrEmpty(avatarUrl))
                                {
                                    <img src="@avatarUrl" alt="Avatar" class="rounded-circle" style="width: 100px; height: 100px; object-fit: cover;" />
                                }
                                <InputFile OnChange="HandleAvatarUpload" class="form-control mt-2" accept="image/*" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Display Name</label>
                            <input type="text" class="form-control" @bind="displayName" placeholder="@userInfo.Email"/>
                        </div>

                        <p><strong>Email:</strong> @userInfo.Email</p>
                        <p><strong>Name:</strong> @userInfo.FirstName @userInfo.LastName</p>
                        <p><strong>Age:</strong> @(userInfo.Age?.ToString() ?? "Not specified")</p>
                        <p><strong>Status:</strong> @userInfo.Status</p>
                        <p><strong>Roles:</strong> @string.Join(", ", userInfo.Roles)</p>

                        <button class="btn btn-primary" @onclick="UpdateProfile" disabled="@isSaving">Save Profile</button>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-body">
                        <h5>Change Password</h5>
                        <div class="mb-3">
                            <label class="form-label">Current Password</label>
                            <input type="password" class="form-control" @bind="currentPassword" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">New Password</label>
                            <input type="password" class="form-control" @bind="newPassword" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Confirm New Password</label>
                            <input type="password" class="form-control" @bind="confirmPassword" />
                        </div>
                        <button class="btn btn-warning" @onclick="ChangePassword" disabled="@isChangingPassword">Change Password</button>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(message))
                {
                    <div class="alert alert-info">@message</div>
                }

                <button class="btn btn-secondary mt-3" @onclick="Logout">Logout</button>
            }
        </Authorized>
        <NotAuthorized>
            <p>Redirecting to login...</p>
        </NotAuthorized>
    </AuthorizeView>
</div>

@code {
    private UserInfo? userInfo;
    private string displayName = string.Empty;
    private string? avatarUrl;
    private string currentPassword = string.Empty;
    private string newPassword = string.Empty;
    private string confirmPassword = string.Empty;
    private bool isSaving = false;
    private bool isChangingPassword = false;
    private string message = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            userInfo = await Http.GetFromJsonAsync<UserInfo>("api/auth/me");
            // Load profile data if endpoint exists
            try
            {
                var profile = await Http.GetFromJsonAsync<ProfileData>("api/profile");
                if (profile != null)
                {
                    displayName = profile.DisplayName ?? string.Empty;
                    avatarUrl = profile.AvatarPath;
                }
            }
            catch { }
        }
        catch
        {
            Navigation.NavigateTo("/login");
        }
    }

    private async Task HandleAvatarUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null && file.Size < 5 * 1024 * 1024) // 5MB limit
        {
            try
            {
                var buffer = new byte[file.Size];
                await file.OpenReadStream(5 * 1024 * 1024).ReadAsync(buffer);
                
                var content = new MultipartFormDataContent();
                content.Add(new ByteArrayContent(buffer), "file", file.Name);

                var response = await Http.PostAsync("api/profile/avatar", content);
                if (response.IsSuccessStatusCode)
                {
                    var result = await response.Content.ReadFromJsonAsync<AvatarUploadResult>();
                    avatarUrl = result?.Url;
                    message = "Avatar uploaded successfully";
                }
            }
            catch (Exception ex)
            {
                message = $"Error uploading avatar: {ex.Message}";
            }
        }
        else
        {
            message = "File too large (max 5MB)";
        }
    }

    private async Task UpdateProfile()
    {
        isSaving = true;
        message = string.Empty;
        try
        {
            var updateRequest = new { DisplayName = displayName };
            var response = await Http.PutAsJsonAsync("api/profile", updateRequest);
            
            if (response.IsSuccessStatusCode)
            {
                message = "Profile updated successfully";
            }
            else
            {
                message = "Error updating profile";
            }
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ChangePassword()
    {
        if (string.IsNullOrEmpty(currentPassword) || string.IsNullOrEmpty(newPassword))
        {
            message = "Please fill all password fields";
            return;
        }

        if (newPassword != confirmPassword)
        {
            message = "New passwords don't match";
            return;
        }

        isChangingPassword = true;
        message = string.Empty;
        try
        {
            var changeRequest = new
            {
                CurrentPassword = currentPassword,
                NewPassword = newPassword
            };

            var response = await Http.PostAsJsonAsync("api/profile/change-password", changeRequest);
            
            if (response.IsSuccessStatusCode)
            {
                message = "Password changed successfully";
                currentPassword = string.Empty;
                newPassword = string.Empty;
                confirmPassword = string.Empty;
            }
            else
            {
                message = "Error changing password - check current password";
            }
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
        }
        finally
        {
            isChangingPassword = false;
        }
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login");
    }

    private class UserInfo
    {
        public string Id { get; set; } = "";
        public string Email { get; set; } = "";
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public int? Age { get; set; }
        public string Status { get; set; } = "";
        public List<string> Roles { get; set; } = new();
    }

    private class ProfileData
    {
        public string? DisplayName { get; set; }
        public string? AvatarPath { get; set; }
    }

    private class AvatarUploadResult
    {
        public string Url { get; set; } = string.Empty;
    }
}

