@page "/profile"
@attribute [Authorize]

<PageTitle>@ProfileRes.PageTitle</PageTitle>

<div class="profile-container">
    <h2>@ProfileRes.Heading</h2>

    <AuthorizeView>
        <Authorized>
            @if (profile == null)
            {
                <p>@ProfileRes.Loading</p>
            }
            else
            {
                <div class="card mb-3">
                    <div class="card-body">
                        <h5>@ProfileRes.BasicInformation</h5>
                        <div class="mb-3">
                            <label class="form-label">@ProfileRes.LabelAvatar</label>
                            <div>
                                @if (!string.IsNullOrEmpty(avatarDataUrl))
                                {
                                    <img src="@avatarDataUrl" alt="Avatar" class="rounded-circle" style="width: 100px; height: 100px; object-fit: cover;" />
                                }
                                <InputFile OnChange="HandleAvatarUpload" class="form-control mt-2" accept="image/*" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">@ProfileRes.LabelDisplayName</label>
                            <input type="text" class="form-control" @bind="displayName" placeholder="@profile.Email" />
                        </div>

                        <p><strong>@ProfileRes.LabelEmail</strong> @profile.Email</p>
                        <p><strong>@ProfileRes.LabelName</strong> @profile.FirstName @profile.LastName</p>
                        <p><strong>@ProfileRes.LabelDateOfBirth</strong> @(profile.DateOfBirth?.ToString("dd/MM/yyyy") ?? ProfileRes.NotSpecified)</p>

                        <button class="btn btn-primary" @onclick="UpdateProfile" disabled="@isSaving">@ProfileRes.BtnSaveProfile</button>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-body">
                        <h5>@ProfileRes.ChangePassword</h5>
                        <div class="mb-3">
                            <label class="form-label">@ProfileRes.LabelCurrentPassword</label>
                            <input type="password" class="form-control" @bind="currentPassword" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">@ProfileRes.LabelNewPassword</label>
                            <input type="password" class="form-control" @bind="newPassword" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">@ProfileRes.LabelConfirmNewPassword</label>
                            <input type="password" class="form-control" @bind="confirmPassword" />
                        </div>
                        <button class="btn btn-warning" @onclick="ChangePassword" disabled="@isChangingPassword">@ProfileRes.ChangePassword</button>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(message))
                {
                    <div class="alert alert-info">@message</div>
                }

                @if (!_isImpersonating)
                {
                    <button class="btn btn-secondary mt-3" @onclick="Logout">@ProfileRes.BtnLogout</button>
                }
            }
        </Authorized>
        <NotAuthorized>
            <p>@ProfileRes.RedirectingToLogin</p>
        </NotAuthorized>
    </AuthorizeView>
</div>

