@page "/profile"
@attribute [Authorize]

<PageTitle>Profile</PageTitle>

<div class="profile-container">
    <h2>My Profile</h2>

    <AuthorizeView>
        <Authorized>
            @if (profile == null)
            {
                <p>Loading...</p>
            }
            else
            {
                <div class="card mb-3">
                    <div class="card-body">
                        <h5>Basic Information</h5>
                        <div class="mb-3">
                            <label class="form-label">Avatar</label>
                            <div>
                                @if (!string.IsNullOrEmpty(avatarDataUrl))
                                {
                                    <img src="@avatarDataUrl" alt="Avatar" class="rounded-circle" style="width: 100px; height: 100px; object-fit: cover;" />
                                }
                                <InputFile OnChange="HandleAvatarUpload" class="form-control mt-2" accept="image/*" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Display Name</label>
                            <input type="text" class="form-control" @bind="displayName" placeholder="@profile.Email" />
                        </div>

                        <p><strong>Email:</strong> @profile.Email</p>
                        <p><strong>Name:</strong> @profile.FirstName @profile.LastName</p>
                        <p><strong>Date of Birth:</strong> @(profile.DateOfBirth?.ToString("dd/MM/yyyy") ?? "Not specified")</p>

                        <button class="btn btn-primary" @onclick="UpdateProfile" disabled="@isSaving">Save Profile</button>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-body">
                        <h5>Change Password</h5>
                        <div class="mb-3">
                            <label class="form-label">Current Password</label>
                            <input type="password" class="form-control" @bind="currentPassword" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">New Password</label>
                            <input type="password" class="form-control" @bind="newPassword" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Confirm New Password</label>
                            <input type="password" class="form-control" @bind="confirmPassword" />
                        </div>
                        <button class="btn btn-warning" @onclick="ChangePassword" disabled="@isChangingPassword">Change Password</button>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(message))
                {
                    <div class="alert alert-info">@message</div>
                }

                @if (!_isImpersonating)
                {
                    <button class="btn btn-secondary mt-3" @onclick="Logout">Logout</button>
                }
            }
        </Authorized>
        <NotAuthorized>
            <p>Redirecting to login...</p>
        </NotAuthorized>
    </AuthorizeView>
</div>

