@page "/billing"
@attribute [Authorize]

<PageTitle>@BillingRes.PageTitle</PageTitle>

<div class="billing-page">
    <h1>@BillingRes.PageHeading</h1>

    @if (_loading)
    {
        <p>@BillingRes.LoadingBilling</p>
    }
    else if (_error is not null)
    {
        <p class="text-danger">@_error</p>
    }
    else if (_overview is not null)
    {
        @* ── Current Plan Card ── *@
        <div class="billing-section">
            <h2>@BillingRes.CurrentPlan</h2>
            <div class="current-plan-card">
                <div class="plan-info">
                    <div class="plan-name-row">
                        <span class="plan-name">@_overview.CurrentSubscription?.PlanName</span>
                        <span class="tier-badge tier-@_overview.CurrentSubscription?.Tier.ToString().ToLowerInvariant()">
                            @_overview.CurrentSubscription?.Tier
                        </span>
                    </div>

                    <div class="plan-dates">
                        <p><strong>@BillingRes.ActiveSince</strong> @_overview.CurrentSubscription?.StartedAt.ToLocalTime().ToString("dd MMM yyyy")</p>
                        @if (_overview.CurrentSubscription?.ExpiresAt is not null)
                        {
                            <p><strong>@BillingRes.NextRenewal</strong> @_overview.CurrentSubscription.ExpiresAt.Value.ToLocalTime().ToString("dd MMM yyyy")</p>
                        }
                        else
                        {
                            <p><strong>@BillingRes.Renewal</strong> @BillingRes.NoExpiry</p>
                        }
                    </div>

                    @if (_overview.CurrentSubscription?.Features is not null)
                    {
                        <div class="plan-features-summary">
                            <span class="feature-tag">
                                @(_overview.CurrentSubscription.Features.MaxCourses >= 1000
                                    ? BillingRes.UnlimitedCourses
                                    : string.Format(BillingRes.CoursesCountFormat, _overview.CurrentSubscription.Features.MaxCourses))
                            </span>
                            @if (_overview.CurrentSubscription.Features.AssessmentAccess)
                            {
                                <span class="feature-tag">@BillingRes.FeatureAssessments</span>
                            }
                            @if (_overview.CurrentSubscription.Features.CertificateAccess)
                            {
                                <span class="feature-tag">@BillingRes.FeatureCertificates</span>
                            }
                            @if (_overview.CurrentSubscription.Features.PrioritySupport)
                            {
                                <span class="feature-tag">@BillingRes.FeaturePrioritySupport</span>
                            }
                        </div>
                    }
                </div>

                <div class="plan-actions">
                    <button class="btn btn-primary" @onclick="GoToPricing">@BillingRes.ChangePlan</button>
                    @if (_overview.CurrentSubscription?.Tier > SubscriptionTierEnum.Free)
                    {
                        <button class="btn btn-outline-warning" @onclick="CancelSubscription" disabled="@_cancelling">
                            @(_cancelling ? BillingRes.Cancelling : BillingRes.CancelSubscription)
                        </button>
                    }
                </div>

                @if (_cancelMessage is not null)
                {
                    <div class="cancel-msg @(_cancelSuccess ? "msg-success" : "msg-error")">
                        @_cancelMessage
                    </div>
                }
            </div>
        </div>

        @* ── Transaction History ── *@
        <div class="billing-section">
            <h2>@BillingRes.TransactionHistory</h2>

            @if (_overview.Transactions.Count == 0)
            {
                <p class="text-muted">@BillingRes.NoTransactions</p>
            }
            else
            {
                <div class="transactions-table-wrapper">
                    <table class="transactions-table">
                        <thead>
                            <tr>
                                <th>@BillingRes.ColDate</th>
                                <th>@BillingRes.ColDescription</th>
                                <th>@BillingRes.ColPlan</th>
                                <th>@BillingRes.ColAmount</th>
                                <th>@BillingRes.ColReference</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tx in _overview.Transactions)
                            {
                                <tr>
                                    <td>@tx.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                                    <td>
                                        <span class="tx-type tx-type-@tx.Type.ToLowerInvariant()">@tx.Type</span>
                                        <span>@tx.Description</span>
                                    </td>
                                    <td>@tx.PlanName</td>
                                    <td class="@(tx.Amount > 0 ? "amount-charge" : "amount-zero")">
                                        @if (tx.Amount == 0)
                                        {
                                            <span>—</span>
                                        }
                                        else
                                        {
                                            <span>@tx.Currency @tx.Amount.ToString("F2")</span>
                                        }
                                    </td>
                                    <td class="tx-ref">
                                        @if (!string.IsNullOrEmpty(tx.StripeSessionId))
                                        {
                                            <code>@tx.StripeSessionId[..Math.Min(20, tx.StripeSessionId.Length)]…</code>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }
</div>


