@page "/students"
@inject IStudentService StudentService

<PageTitle>Students</PageTitle>

<div class="students-card">
    <div class="students-header">
        <h2 class="students-title">Students</h2>
        <div class="students-actions">
            <button class="btn btn-sm">Add Student</button>
        </div>
    </div>

    <table class="table table-striped table-hover students-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Age</th>
                <th>City</th>
                <th>Profession</th>
            </tr>
        </thead>
        <tbody>
            @if (students == null)
            {
                <tr>
                    <td class="no-data" colspan="4"><em>Loading...</em></td>
                </tr>
            }
            else
            {
                @foreach (var student in students)
                {
                    <tr>
                        <td class="name-strong">@($"{student.FirstName} {student.LastName}")</td>
                        <td>@student.Age</td>
                        <td>@student.City</td>
                        <td><span class="badge">@student.Profession</span></td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@code{
 private IEnumerable<Student>? students;

    protected override async Task OnInitializedAsync()
    {
        students = await StudentService.GetAllAsync();
    }
}