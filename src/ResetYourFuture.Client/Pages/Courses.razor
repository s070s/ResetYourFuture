@page "/courses"
@attribute [Authorize]

<PageTitle>Courses - Reset Your Future</PageTitle>

<h1>Available Courses</h1>

@if (_loading)
{
    <p>Loading courses...</p>
}
else if (_error is not null)
{
    <p class="text-danger">@_error</p>
}
else if (_courses.Count == 0)
{
    <p>No courses available at the moment.</p>
}
else
{
    <div class="courses-list">
        @foreach (var course in _courses)
        {
            var isLocked = _userTier < course.RequiredTier;

            <div class="course-card @(isLocked ? "course-locked" : "")" @onclick="() => ViewCourse(course)">
                <div class="course-card-header">
                    <h3>@course.Title</h3>
                    @if (course.RequiredTier != SubscriptionTier.Free)
                    {
                        <span class="tier-badge tier-@course.RequiredTier.ToString().ToLowerInvariant()">
                            @course.RequiredTier
                        </span>
                    }
                </div>
                @if (!string.IsNullOrEmpty(course.Description))
                {
                    <p class="description">@course.Description</p>
                }
                <div class="meta">
                    <span class="lessons">@course.TotalLessons lessons</span>
                    @if (course.IsEnrolled)
                    {
                        <span class="enrolled-badge">✓ Enrolled</span>
                    }
                    @if (isLocked)
                    {
                        <span class="locked-badge" @onclick:stopPropagation="true" @onclick="GoToPricing">
                            🔒 Upgrade to @course.RequiredTier
                        </span>
                    }
                </div>
            </div>
        }
    </div>
}

<style>
    .courses-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-top: 1rem;
    }

    .course-card {
        border: 1px solid #ddd;
        border-radius: 8px;
        padding: 1.5rem;
        cursor: pointer;
        transition: box-shadow 0.2s, border-color 0.2s;
    }

    .course-card:hover {
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        border-color: #007bff;
    }

    .course-card h3 {
        margin: 0 0 0.5rem 0;
        color: #333;
    }

    .course-card .description {
        color: #666;
        margin-bottom: 1rem;
    }

    .course-card .meta {
        display: flex;
        gap: 1rem;
        font-size: 0.9rem;
        color: #888;
    }

    .enrolled-badge {
        color: #28a745;
        font-weight: bold;
    }

    .course-card-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 0.5rem;
    }

    .tier-badge {
        font-size: 0.75rem;
        font-weight: 600;
        padding: 0.2rem 0.6rem;
        border-radius: 12px;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .tier-badge.tier-plus {
        background: #e8f4fd;
        color: #0c5460;
    }

    .tier-badge.tier-pro {
        background: #fff3cd;
        color: #856404;
    }

    .course-locked {
        opacity: 0.7;
        border-style: dashed;
    }

    .locked-badge {
        color: #dc3545;
        font-weight: bold;
        cursor: pointer;
        font-size: 0.85rem;
    }

    .locked-badge:hover {
        text-decoration: underline;
    }
</style>

