@page "/courses"
@attribute [Authorize]

<PageTitle>@CourseRes.CoursesPageTitle</PageTitle>

<h1>@CourseRes.AvailableCourses</h1>

@if (_loading)
{
    <p>@CourseRes.LoadingCourses</p>
}
else if (_error is not null)
{
    <p class="text-danger">@_error</p>
}
else if (_pagedResult is null || _pagedResult.TotalCount == 0)
{
    <p>@CourseRes.NoCoursesAvailable</p>
}
else
{
    <div class="pagination-toolbar">
        <span class="pagination-info">
            @string.Format(CourseRes.TotalCoursesFormat, _pagedResult.TotalCount)
        </span>
        <div class="page-size-selector">
            <label for="pageSizeSelect">@CourseRes.PerPage</label>
            <select id="pageSizeSelect" class="form-select form-select-sm"
                    value="@_pageSize"
                    @onchange="e => ChangePageSize(int.Parse(e.Value!.ToString()!))">
                @foreach (var size in PageSizeOptions)
                {
                    <option value="@size" selected="@(_pageSize == size)">@size</option>
                }
            </select>
        </div>
    </div>

    <div class="courses-list">
        @foreach (var course in _pagedResult.Items)
        {
            var isLocked = _userTier < course.RequiredTier;

            <div class="course-card @(isLocked ? "course-locked" : "")" @key="course.Id" @onclick="() => ViewCourse(course)">
                <div class="course-card-header">
                    <h3>@course.Title</h3>
                    @if (course.RequiredTier != SubscriptionTierEnum.Free)
                    {
                        <span class="tier-badge tier-@course.RequiredTier.ToString().ToLowerInvariant()">
                            @course.RequiredTier
                        </span>
                    }
                </div>
                @if (!string.IsNullOrEmpty(course.Description))
                {
                    <div class="description">@((MarkupString)course.Description)</div>
                }
                <div class="meta">
                    <span class="lessons">@string.Format(CourseRes.LessonsCountFormat, course.TotalLessons)</span>
                    @if (course.IsEnrolled)
                    {
                        <span class="enrolled-badge">@CourseRes.Enrolled</span>
                    }
                    @if (isLocked)
                    {
                        <span class="locked-badge" @onclick:stopPropagation="true" @onclick="GoToPricing">
                            @string.Format(CourseRes.UpgradeToFormat, course.RequiredTier)
                        </span>
                    }
                </div>
            </div>
        }
    </div>

    @if (_pagedResult.TotalPages > 1)
    {
        <nav class="pagination-nav" aria-label="Course pages">
            <button class="pagination-btn"
                    disabled="@(!_pagedResult.HasPreviousPage)"
                    @onclick="() => GoToPage(_page - 1)">
                ‹ @CourseRes.Previous
            </button>

            @for (int p = 1; p <= _pagedResult.TotalPages; p++)
            {
                var pageNum = p;
                <button class="pagination-btn @(_page == pageNum ? "active" : "")"
                        @onclick="() => GoToPage(pageNum)"
                        @key="pageNum">
                    @pageNum
                </button>
            }

            <button class="pagination-btn"
                    disabled="@(!_pagedResult.HasNextPage)"
                    @onclick="() => GoToPage(_page + 1)">
                @CourseRes.Next ›
            </button>
        </nav>
    }
}


