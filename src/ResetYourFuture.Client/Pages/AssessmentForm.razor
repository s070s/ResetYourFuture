@page "/assessments/{AssessmentId:guid}"
@attribute [Authorize(Roles = "Student")]

<h3>@assessment?.Title</h3>

@if (assessment == null)
{
    <p>@AssessmentRes.Loading</p>
}
else if (submitted)
{
    <div class="alert alert-success">
        <h4>@AssessmentRes.SubmittedTitle</h4>
        <p>@AssessmentRes.SubmittedMessage</p>
        <button class="btn btn-primary" @onclick="ViewHistory">@AssessmentRes.ViewSubmissions</button>
    </div>
}
else
{
    <p>@assessment.Description</p>

    <EditForm Model="@answers" OnValidSubmit="@HandleSubmit">
        @if (questions != null)
        {
            @foreach (var question in questions)
            {
                <div class="mb-3">
                    <label class="form-label">
                        <strong>@question.DisplayLabel</strong>
                        @if (question.Required)
                        {
                            <span class="text-danger"> *</span>
                        }
                    </label>
                    @if (question.Type == "text")
                    {
                        <input type="text" class="form-control" @bind="answers[question.Id]" />
                    }
                    else if (question.Type is "choice" or "single-select")
                    {
                        <select class="form-select" @bind="answers[question.Id]">
                            <option value="">@AssessmentRes.SelectPlaceholder</option>
                            @foreach (var option in question.Options ?? new List<string>())
                            {
                                <option value="@option">@option</option>
                            }
                        </select>
                    }
                    else if (question.Type == "multi-select")
                    {
                        @foreach (var option in question.Options ?? new List<string>())
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="@($"{question.Id}_{option}")"
                                       @onchange="@(e => ToggleMultiSelect(question.Id, option, (bool)e.Value!))" />
                                <label class="form-check-label" for="@($"{question.Id}_{option}")">@option</label>
                            </div>
                        }
                    }
                    else if (question.Type is "rating" or "likert")
                    {
                        <div class="btn-group" role="group">
                            @for (int i = question.Min; i <= question.Max; i++)
                            {
                                var value = i;
                                <input type="radio" class="btn-check" name="@question.Id" id="@($"{question.Id}_{i}")"
                                       @onchange="@(() => answers[question.Id] = value.ToString())" />
                                <label class="btn btn-outline-primary" for="@($"{question.Id}_{i}")">@i</label>
                            }
                        </div>
                    }
                    else if (question.Type == "date")
                    {
                        <input type="date" class="form-control"
                               value="@answers[question.Id]"
                               @onchange="@(e => answers[question.Id] = e.Value?.ToString() ?? string.Empty)" />
                    }
                </div>
            }
        }

        <button type="submit" class="btn btn-primary" disabled="@isSubmitting">@AssessmentRes.SubmitAssessment</button>
    </EditForm>
}

