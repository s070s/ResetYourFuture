@page "/forgot-password"

<PageTitle>Forgot Password</PageTitle>

<div class="auth-container">
    <h2>Forgot Password</h2>

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success">
            @successMessage
            <div class="mt-3">
                <p><strong>Dev Mode:</strong> Reset password directly</p>
                <input type="password" class="form-control mb-2" @bind="devNewPassword" placeholder="New password" />
                <button class="btn btn-sm btn-warning" @onclick="DevResetPassword">Dev: Reset Password</button>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    @if (string.IsNullOrEmpty(successMessage))
    {
        <p>Enter your email address and we'll send you a password reset link.</p>

        <EditForm Model="@forgotPasswordRequest" OnValidSubmit="HandleSubmit">
            <div class="mb-3">
                <label for="email" class="form-label">Email</label>
                <input type="email" id="email" class="form-control" @bind="forgotPasswordRequest.Email" required />
            </div>

            <button type="submit" class="btn btn-primary" disabled="@isLoading">
                @if (isLoading) { <span>Sending...</span> } else { <span>Send Reset Link</span> }
            </button>
        </EditForm>
    }

    <p class="mt-3">
        <a href="/login">Back to Login</a>
    </p>
</div>

