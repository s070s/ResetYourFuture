@page "/admin/assessments/new"
@page "/admin/assessments/{AssessmentId:guid}/edit"
@using ResetYourFuture.Client.Shared
@attribute [Authorize(Roles = "Admin")]

<PageTitle>@(IsNew ? "Create Assessment" : "Edit Assessment")</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@(IsNew ? "Create Assessment" : "Edit Assessment")</h2>
    <button class="btn btn-secondary" @onclick="GoBack">← Back to Assessments</button>
</div>

@if (!IsNew && loading)
{
    <p>Loading...</p>
}
else
{
    <div class="card mb-4">
        <div class="card-header">Assessment Details</div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Key <small class="text-muted">(unique identifier, e.g. career_clarity_v1)</small></label>
                    <input class="form-control" @bind="assessmentKey" placeholder="my_assessment_v1" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Title</label>
                    <input class="form-control" @bind="assessmentTitle" />
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Description</label>
                <QuillEditor @ref="descriptionEditor" Content="@assessmentDescription" MinHeight="120px" />
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>Questions</span>
            <button class="btn btn-sm btn-success" @onclick="AddQuestion">+ Add Question</button>
        </div>
        <div class="card-body">
            @if (questions.Count == 0)
            {
                <p class="text-muted">No questions yet. Click "Add Question" to start building your assessment.</p>
            }
            else
            {
                @for (var i = 0; i < questions.Count; i++)
                {
                    var q = questions[i];
                    var index = i;
                    <div class="card mb-3 border-start border-primary border-3" @key="q.TempId">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <strong>Question @(index + 1)</strong>
                                <div>
                                    @if (index > 0)
                                    {
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => MoveQuestion(index, -1)" title="Move up">↑</button>
                                    }
                                    @if (index < questions.Count - 1)
                                    {
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => MoveQuestion(index, 1)" title="Move down">↓</button>
                                    }
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveQuestion(index)" title="Remove">✕</button>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-2">
                                    <label class="form-label">Question ID</label>
                                    <input class="form-control form-control-sm" @bind="q.Id" placeholder="q1" />
                                </div>
                                <div class="col-md-3 mb-2">
                                    <label class="form-label">Type</label>
                                    <select class="form-select form-select-sm" @bind="q.Type">
                                        <option value="text">Text (free input)</option>
                                        <option value="rating">Rating (scale)</option>
                                        <option value="choice">Choice (select one)</option>
                                    </select>
                                </div>
                                <div class="col-md-3 mb-2">
                                    <label class="form-label">Required</label>
                                    <select class="form-select form-select-sm" @bind="q.Required">
                                        <option value="true">Yes</option>
                                        <option value="false">No</option>
                                    </select>
                                </div>
                            </div>

                            <div class="mb-2">
                                <label class="form-label">Label / Question Text</label>
                                <input class="form-control form-control-sm" @bind="q.Label" placeholder="Enter the question text..." />
                            </div>

                            @if (q.Type == "rating")
                            {
                                <div class="row">
                                    <div class="col-md-6 mb-2">
                                        <label class="form-label">Min</label>
                                        <input type="number" class="form-control form-control-sm" @bind="q.Min" />
                                    </div>
                                    <div class="col-md-6 mb-2">
                                        <label class="form-label">Max</label>
                                        <input type="number" class="form-control form-control-sm" @bind="q.Max" />
                                    </div>
                                </div>
                            }

                            @if (q.Type == "choice")
                            {
                                <div class="mb-2">
                                    <label class="form-label">Options <small class="text-muted">(one per line)</small></label>
                                    <textarea class="form-control form-control-sm" rows="4"
                                              @bind="q.OptionsText"
                                              placeholder="Option 1&#10;Option 2&#10;Option 3"></textarea>
                                </div>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">Schema Preview</div>
        <div class="card-body">
            <pre class="bg-light p-3 rounded" style="max-height: 300px; overflow-y: auto; font-size: 0.85rem;">@GenerateSchemaJson()</pre>
        </div>
    </div>

    <div class="mb-4">
        <button class="btn btn-primary" @onclick="SaveAssessment" disabled="@isSaving">
            @(isSaving ? "Saving..." : "Save Assessment")
        </button>
        <button class="btn btn-secondary" @onclick="GoBack">Cancel</button>
    </div>
}

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-info alert-dismissible mt-3">
        @message
        <button type="button" class="btn-close" @onclick="() => message = string.Empty"></button>
    </div>
}

