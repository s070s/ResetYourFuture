@page "/admin/certificates"
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Admin — Certificates</PageTitle>

<h2>Certificates</h2>

@if (!_loaded)
{
    <p>Loading…</p>
}
else if (_pagedResult is null || !_pagedResult.Items.Any())
{
    <p>No certificates have been issued yet.</p>
}
else
{
    <VirtualizedTable Items="_pagedResult.Items" TItem="AdminCertificateListItemDto">
        <HeaderRow>
            <tr>
                <th>Recipient</th>
                <th>Email</th>
                <th>Course</th>
                <th>Issued</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </HeaderRow>
        <RowTemplate Context="cert">
            <tr @key="cert.Id">
                <td>@cert.RecipientName</td>
                <td>@cert.UserEmail</td>
                <td>@cert.CourseTitle</td>
                <td>@cert.IssuedAt.ToString("yyyy-MM-dd")</td>
                <td>
                    <StatusBadge IsActive="@(cert.Status == "Active")"
                                 ActiveText="Active"
                                 InactiveText="Revoked"
                                 InactiveClass="bg-danger" />
                </td>
                <td>
                    <button class="btn btn-sm btn-warning me-1"
                            disabled="@(cert.Status != "Active")"
                            @onclick="() => PromptRevoke(cert.Id)">
                        Revoke
                    </button>
                    <button class="btn btn-sm btn-outline-secondary"
                            @onclick="() => RegenerateAsync(cert.Id)">
                        Regen PDF
                    </button>
                </td>
            </tr>
        </RowTemplate>
    </VirtualizedTable>

    <AdminPaginationToolbar CurrentPage="_pagedResult.Page"
                            TotalPages="_pagedResult.TotalPages"
                            TotalCount="_pagedResult.TotalCount"
                            PageSize="_pagedResult.PageSize"
                            HasPreviousPage="_pagedResult.HasPreviousPage"
                            HasNextPage="_pagedResult.HasNextPage"
                            PageSizeOptions="PageSizeOptions"
                            ItemLabel="certificates"
                            OnPageSizeChanged="OnPageSizeChanged"
                            OnPreviousPage="() => GoToPage(_pagedResult.Page - 1)"
                            OnNextPage="() => GoToPage(_pagedResult.Page + 1)" />
}

<ConfirmModal IsVisible="@(_pendingRevokeId.HasValue)"
              Title="Revoke Certificate"
              Message="This will permanently revoke the certificate. The student will no longer be able to download or verify it. Continue?"
              ConfirmLabel="Revoke"
              ConfirmButtonClass="btn-danger"
              OnConfirm="ExecuteRevokeAsync"
              OnCancel="@(() => _pendingRevokeId = null)" />

<DismissibleAlert Message="@_message" AlertType="@_alertType" OnDismiss="@(() => _message = string.Empty)" />
