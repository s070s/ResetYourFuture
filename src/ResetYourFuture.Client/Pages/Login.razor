@page "/login"

<PageTitle>@GlobalRes.Label_Login</PageTitle>

<div class="auth-container">
    <h2>@GlobalRes.Label_Login</h2>

    @if (!string.IsNullOrEmpty(devSuccessMessage))
    {
        <div class="alert alert-success">@devSuccessMessage</div>
    }

    @if (unconfirmedEmailPending)
    { 
        @if (Env.IsDevelopment())
        {
            <div class="mt-2">
                <button class="btn btn-sm btn-warning" @onclick="DevConfirmPendingEmail">@GlobalRes.Label_ConfirmEmail</button>
            </div>
        }

    }

    @if (!string.IsNullOrEmpty(errorMessage) && !unconfirmedEmailPending)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    <EditForm Model="loginRequest" OnValidSubmit="HandleLogin" autocomplete="off">
        <DataAnnotationsValidator />

        <div class="mb-3">
            <label for="email" class="form-label">@GlobalRes.Label_Info_Email</label>
            <InputText id="email" class="form-control" @bind-Value="loginRequest.Email" />
            <ValidationMessage For="@(() => loginRequest.Email)" />
        </div>

        <div class="mb-3">
            <label for="password" class="form-label">@GlobalRes.Label_Password</label>
            <div class="input-group">
                <InputText id="password" type="@passwordInputType" class="form-control" @bind-Value="loginRequest.Password" />
                <button type="button" class="btn btn-password-toggle" @onclick="TogglePasswordVisibility" tabindex="-1">
                    <i class="@passwordIconClass"></i>
                </button>
            </div>
            <ValidationMessage For="@(() => loginRequest.Password)" />
        </div>

        <div class="mb-3 form-check">
            <InputCheckbox id="rememberMe" class="form-check-input" @bind-Value="loginRequest.RememberMe" />
            <label class="form-check-label" for="rememberMe">@GlobalRes.Label_RememberMe</label>
        </div>

        <button type="submit" class="btn btn-primary" disabled="@isLoading">
            @if (isLoading) { <span>@GlobalRes.Label_LoggingIn</span> } else { <span>@GlobalRes.Label_Login</span> }
        </button>
    </EditForm>

    <p class="mt-3">
        Don't have an account? <a href="/register">@GlobalRes.Label_Register</a>
    </p>
    <p>
        <a href="/forgot-password">@GlobalRes.Label_ForgotPassword</a>
    </p>
</div>

