@page "/admin/assessments"
@using Microsoft.AspNetCore.Authorization
@using ResetYourFuture.Shared.Models.Assessments
@using Microsoft.JSInterop
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JSRuntime
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Assessment Management</PageTitle>

<h2>Assessment Management</h2>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="() => showCreateModal = true">Create New Assessment</button>
</div>

@if (assessments == null)
{
    <p>Loading...</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Key</th>
                    <th>Status</th>
                    <th>Submissions</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var assessment in assessments)
                {
                    <tr>
                        <td>@assessment.Title</td>
                        <td>@assessment.Key</td>
                        <td>
                            <span class="badge @(assessment.IsPublished ? "bg-success" : "bg-secondary")">
                                @(assessment.IsPublished ? "Published" : "Draft")
                            </span>
                        </td>
                        <td>@assessment.SubmissionCount</td>
                        <td>
                            <button class="btn btn-sm btn-primary" @onclick="() => EditAssessment(assessment)">Edit</button>
                            @if (assessment.IsPublished)
                            {
                                <button class="btn btn-sm btn-warning" @onclick="() => UnpublishAssessment(assessment.Id)">Unpublish</button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-success" @onclick="() => PublishAssessment(assessment.Id)">Publish</button>
                            }
                            <button class="btn btn-sm btn-info" @onclick="() => ViewSubmissions(assessment.Id)">Submissions</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteAssessment(assessment.Id)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (showCreateModal || editingAssessment != null)
{
    <div class="modal" tabindex="-1" style="display: block; background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editingAssessment == null ? "Create Assessment" : "Edit Assessment")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="@assessmentModel" OnValidSubmit="@HandleSave">
                        <div class="mb-3">
                            <label class="form-label">Key</label>
                            <InputText class="form-control" @bind-Value="assessmentModel.Key" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Title</label>
                            <InputText class="form-control" @bind-Value="assessmentModel.Title" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <InputTextArea class="form-control" @bind-Value="assessmentModel.Description" rows="3" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Schema JSON</label>
                            <textarea class="form-control" @bind="assessmentModel.SchemaJson" rows="10" style="font-family: monospace;"></textarea>
                            <small class="text-muted">Example: {"Questions":[{"Id":"q1","Text":"Your name?","Type":"text"}]}</small>
                        </div>

                        <button type="submit" class="btn btn-primary">Save</button>
                        <button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-info mt-3">@message</div>
}

@code {
    private List<AssessmentDefinitionListItemDto>? assessments;
    private bool showCreateModal = false;
    private AssessmentDefinitionListItemDto? editingAssessment;
    private AssessmentModel assessmentModel = new();
    private string message = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadAssessments();
    }

    private async Task LoadAssessments()
    {
        try
        {
            assessments = await Http.GetFromJsonAsync<List<AssessmentDefinitionListItemDto>>("api/admin/assessments");
        }
        catch (Exception ex)
        {
            message = $"Error loading assessments: {ex.Message}";
        }
    }

    private async Task EditAssessment(AssessmentDefinitionListItemDto assessment)
    {
        try
        {
            var fullAssessment = await Http.GetFromJsonAsync<AssessmentDefinitionDto>($"api/admin/assessments/{assessment.Id}");
            if (fullAssessment != null)
            {
                editingAssessment = assessment;
                assessmentModel = new AssessmentModel
                {
                    Key = fullAssessment.Key,
                    Title = fullAssessment.Title,
                    Description = fullAssessment.Description,
                    SchemaJson = fullAssessment.SchemaJson
                };
            }
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
        }
    }

    private async Task HandleSave()
    {
        try
        {
            var request = new SaveAssessmentDefinitionRequest(
                assessmentModel.Key,
                assessmentModel.Title,
                assessmentModel.Description,
                assessmentModel.SchemaJson
            );

            HttpResponseMessage response;
            if (editingAssessment == null)
            {
                response = await Http.PostAsJsonAsync("api/admin/assessments", request);
            }
            else
            {
                response = await Http.PutAsJsonAsync($"api/admin/assessments/{editingAssessment.Id}", request);
            }

            if (response.IsSuccessStatusCode)
            {
                await LoadAssessments();
                CloseModal();
                message = "Assessment saved successfully";
            }
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
        }
    }

    private void CloseModal()
    {
        showCreateModal = false;
        editingAssessment = null;
        assessmentModel = new();
    }

    private async Task PublishAssessment(Guid id)
    {
        try
        {
            var response = await Http.PostAsync($"api/admin/assessments/{id}/publish", null);
            if (response.IsSuccessStatusCode)
            {
                await LoadAssessments();
                message = "Assessment published";
            }
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
        }
    }

    private async Task UnpublishAssessment(Guid id)
    {
        try
        {
            var response = await Http.PostAsync($"api/admin/assessments/{id}/unpublish", null);
            if (response.IsSuccessStatusCode)
            {
                await LoadAssessments();
                message = "Assessment unpublished";
            }
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
        }
    }

    private void ViewSubmissions(Guid id)
    {
        Nav.NavigateTo($"/admin/assessments/{id}/submissions");
    }

    private async Task DeleteAssessment(Guid id)
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this assessment?"))
            return;

        try
        {
            var response = await Http.DeleteAsync($"api/admin/assessments/{id}");
            if (response.IsSuccessStatusCode)
            {
                await LoadAssessments();
                message = "Assessment deleted";
            }
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
        }
    }

    private class AssessmentModel
    {
        public string Key { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string SchemaJson { get; set; } = "{}";
    }
}
