@page "/admin/assessments"
@attribute [Authorize(Roles = "Admin")]

<PageTitle>@AdminRes.AssessmentManagement</PageTitle>

<h2>@AdminRes.AssessmentManagement</h2>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="CreateAssessment">@AdminRes.CreateNewAssessment</button>
</div>

@if (assessments == null)
{
    <p>@AdminRes.Loading</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>@AdminRes.FieldTitle</th>
                    <th>@AdminRes.FieldKey</th>
                    <th>@AdminRes.ColStatus</th>
                    <th>@AdminRes.ColSubmissions</th>
                    <th>@AdminRes.ColActions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var assessment in assessments)
                {
                    <tr>
                        <td>@assessment.Title</td>
                        <td>@assessment.Key</td>
                        <td>
                            <span class="badge @(assessment.IsPublished ? "bg-success" : "bg-secondary")">
                                @(assessment.IsPublished ? AdminRes.StatusPublished : AdminRes.StatusDraft)
                            </span>
                        </td>
                        <td>@assessment.SubmissionCount</td>
                        <td>
                            <button class="btn btn-sm btn-primary" @onclick="() => EditAssessment(assessment.Id)">@AdminRes.Edit</button>
                            @if (assessment.IsPublished)
                            {
                                <button class="btn btn-sm btn-warning" @onclick="() => UnpublishAssessment(assessment.Id)">@AdminRes.Unpublish</button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-success" @onclick="() => PublishAssessment(assessment.Id)">@AdminRes.Publish</button>
                            }
                            <button class="btn btn-sm btn-info" @onclick="() => ViewSubmissions(assessment.Id)">@AdminRes.ColSubmissions</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteAssessment(assessment.Id)">@AdminRes.Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-info alert-dismissible mt-3">
        @message
        <button type="button" class="btn-close" @onclick="() => message = string.Empty"></button>
    </div>
}

