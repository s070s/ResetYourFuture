@page "/admin/assessments/{AssessmentId:guid}/submissions"
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Assessment Submissions</PageTitle>

<div class="mb-3">
    <button class="btn btn-outline-secondary" @onclick="GoBack">← Back to Assessments</button>
</div>

<h2>Submissions@(assessmentTitle != null ? $" — {assessmentTitle}" : "")</h2>

@if (submissions == null)
{
    <p>Loading...</p>
}
else if (submissions.Count == 0)
{
    <div class="alert alert-info">No submissions yet for this assessment.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Email</th>
                    <th>Submitted At</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var sub in submissions)
                {
                    <tr @key="sub.Id">
                        <td>@sub.UserDisplayName</td>
                        <td>@sub.UserEmail</td>
                        <td>@sub.SubmittedAt.LocalDateTime.ToString("g")</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary"
                                    @onclick="() => ToggleAnswers(sub.Id)">
                                @(expandedSubmissionId == sub.Id ? "Hide Answers" : "View Answers")
                            </button>
                        </td>
                    </tr>
                    @if (expandedSubmissionId == sub.Id)
                    {
                        <tr>
                            <td colspan="4">
                                <div class="card card-body bg-light">
                                    @{ var parsed = ParseAnswers(sub.AnswersJson); }
                                    @if (parsed.Count > 0)
                                    {
                                        <dl class="row mb-0">
                                            @foreach (var kv in parsed)
                                            {
                                                <dt class="col-sm-4">@ResolveLabel(kv.Key)</dt>
                                                <dd class="col-sm-8">@(string.IsNullOrEmpty(kv.Value) ? "—" : kv.Value)</dd>
                                            }
                                        </dl>
                                    }
                                    else
                                    {
                                        <pre class="mb-0">@sub.AnswersJson</pre>
                                    }
                                    @if (!string.IsNullOrEmpty(sub.SummaryJson))
                                    {
                                        <hr />
                                        <h6>Summary</h6>
                                        <pre class="mb-0">@sub.SummaryJson</pre>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3">@errorMessage</div>
}

