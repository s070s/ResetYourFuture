@page "/"

<PageTitle>Reset Your Future | Career Guidance</PageTitle>

<!-- Hero Section -->
<section class="hero-section">
    <div class="hero-bg-overlay"></div>
    <div class="hero-glow hero-glow-1"></div>
    <div class="hero-glow hero-glow-2"></div>
    
    <div class="container hero-content">
        <div class="hero-text">
            <h1 class="hero-title">
                Από την απογοήτευση στη σαφήνεια<br>
                <span class="text-gradient">Από το Zero στο Hero</span>
            </h1>
            <p class="hero-subtitle">
                Η πρώτη ελληνική online πλατφόρμα που συνδυάζει επαγγελματικό προσανατολισμό 
                με ψυχοκοινωνική ενδυνάμωση για μαθητές και αποφοίτους Λυκείου.
            </p>
            <div class="hero-cta">
                <button class="btn-cta">
                    Κλείσε δωρεάν διαγνωστική συνεδρία 20'
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14"></path>
                        <path d="m12 5 7 7-7 7"></path>
                    </svg>
                </button>
            </div>
        </div>
    </div>
    
    <div class="scroll-indicator">
        <div class="scroll-mouse">
            <div class="scroll-dot"></div>
        </div>
    </div>
</section>

<!-- Problem Section -->
<section class="section section-problem">
    <div class="container">
        <div class="section-content">
            <h2 class="section-title">
                Αν αυτά σου φαίνονται γνώριμα, <span class="text-gradient">είσαι στο σωστό μέρος</span>
            </h2>
            
            <div class="problem-grid">
                <div class="problem-card">
                    <div class="problem-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" x2="12" y1="8" y2="12"></line>
                            <line x1="12" x2="12.01" y1="16" y2="16"></line>
                        </svg>
                    </div>
                    <p>Δεν πέτυχες τους βαθμούς που περίμενες</p>
                </div>
                
                <div class="problem-card">
                    <div class="problem-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" x2="12" y1="8" y2="12"></line>
                            <line x1="12" x2="12.01" y1="16" y2="16"></line>
                        </svg>
                    </div>
                    <p>Νιώθεις χαμένος χωρίς ξεκάθαρη κατεύθυνση</p>
                </div>
                
                <div class="problem-card">
                    <div class="problem-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" x2="12" y1="8" y2="12"></line>
                            <line x1="12" x2="12.01" y1="16" y2="16"></line>
                        </svg>
                    </div>
                    <p>Αισθάνεσαι πίεση από γονείς και κοινωνία</p>
                </div>
                
                <div class="problem-card">
                    <div class="problem-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" x2="12" y1="8" y2="12"></line>
                            <line x1="12" x2="12.01" y1="16" y2="16"></line>
                        </svg>
                    </div>
                    <p>Αμφισβητείς τον εαυτό σου και τις δυνατότητές σου</p>
                </div>
            </div>
            
            <p class="problem-conclusion">
                Δεν είσαι αποτυχημένος. <span class="text-gradient font-bold">Απλώς κανείς δεν σου έμαθε πώς να διαχειρίζεσαι την αποτυχία.</span>
            </p>
        </div>
    </div>
</section>

<!-- Solution Section -->
<section class="section section-solution">
    <div class="container">
        <h2 class="section-title">
            Τι είναι το <span class="text-gradient">Reset Your Future</span>
        </h2>
        
        <div class="solution-grid">
            <div class="solution-card">
                <div class="solution-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 7v14"></path>
                        <path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"></path>
                    </svg>
                </div>
                <h3>Online Courses</h3>
                <p>Δομημένα μαθήματα αυτογνωσίας, ανθεκτικότητας και λήψης αποφάσεων.</p>
            </div>
            
            <div class="solution-card">
                <div class="solution-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path>
                    </svg>
                </div>
                <h3>Συμβουλευτικές Συνεδρίες</h3>
                <p>Ατομική και ομαδική υποστήριξη με ξεκάθαρο πλάνο δράσης.</p>
            </div>
            
            <div class="solution-card">
                <div class="solution-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                        <circle cx="9" cy="7" r="4"></circle>
                        <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                    </svg>
                </div>
                <h3>Κοινότητα Υποστήριξης</h3>
                <p>Δεν είσαι μόνος. Μαθαίνεις και εξελίσσεσαι μαζί με άλλους.</p>
            </div>
        </div>
    </div>
</section>

<!-- Method Section -->
<section class="section section-method">
    <div class="method-glow method-glow-1"></div>
    <div class="method-glow method-glow-2"></div>
    
    <div class="container">
        <h2 class="section-title">
            Από το <span class="text-light-muted">Zero State</span> στο <span class="text-gradient">Hero State</span>
        </h2>
        
        <div class="method-grid">
            <div class="state-card zero-state">
                <div class="state-header">
                    <span class="state-dot zero-dot"></span>
                    <h3>Zero State</h3>
                </div>
                <ul class="state-list">
                    <li><span class="bullet zero-bullet"></span>Ανασφάλεια</li>
                    <li><span class="bullet zero-bullet"></span>Σύγχυση</li>
                    <li><span class="bullet zero-bullet"></span>Φόβος αποτυχίας</li>
                    <li><span class="bullet zero-bullet"></span>Κοινωνική πίεση</li>
                </ul>
            </div>
            
            <div class="arrow-container">
                <div class="arrow-line"></div>
                <div class="arrow-circle">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14"></path>
                        <path d="m12 5 7 7-7 7"></path>
                    </svg>
                </div>
                <div class="arrow-line"></div>
            </div>
            
            <div class="state-card hero-state">
                <div class="state-header">
                    <span class="state-dot hero-dot"></span>
                    <h3 class="text-gradient">Hero State</h3>
                </div>
                <ul class="state-list">
                    <li><span class="bullet hero-bullet"></span>Αυτογνωσία</li>
                    <li><span class="bullet hero-bullet"></span>Ανθεκτικότητα</li>
                    <li><span class="bullet hero-bullet"></span>Ελπίδα</li>
                    <li><span class="bullet hero-bullet"></span>Αυτοπεποίθηση</li>
                    <li><span class="bullet hero-bullet"></span>Δράση</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<!-- Story Section -->
<section class="section section-story">
    <div class="container">
        <h2 class="section-title">
            Η ιστορία πίσω από το <span class="text-gradient">Reset Your Future</span>
        </h2>
        
        <div class="story-card">
            <div class="quote-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 3a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2 1 1 0 0 1 1 1v1a2 2 0 0 1-2 2 1 1 0 0 0-1 1v2a1 1 0 0 0 1 1 6 6 0 0 0 6-6V5a2 2 0 0 0-2-2z"></path>
                    <path d="M5 3a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2 1 1 0 0 1 1 1v1a2 2 0 0 1-2 2 1 1 0 0 0-1 1v2a1 1 0 0 0 1 1 6 6 0 0 0 6-6V5a2 2 0 0 0-2-2z"></path>
                </svg>
            </div>
            
            <blockquote>
                «Το 2014 απέτυχα στις Πανελλαδικές. Ένιωσα χαμένος και χωρίς κατεύθυνση. 
                Σήμερα βοηθάω μαθητές να μετατρέψουν την αποτυχία σε δύναμη και σχέδιο δράσης.»
            </blockquote>
            
            <div class="author">
                <div class="author-avatar">
                    <span class="text-gradient">ΓΚ</span>
                </div>
                <div class="author-info">
                    <p class="author-name">Γεώργιος Κόκκαλης</p>
                    <p class="author-title">Ιδρυτής</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="section section-cta">
    <div class="cta-glow"></div>
    
    <div class="container">
        <div class="cta-card">
            <h2 class="cta-title">
                Το επόμενο βήμα <span class="text-gradient">ξεκινά εδώ</span>
            </h2>
            <p class="cta-text">
                Κλείσε δωρεάν μια σύντομη διαγνωστική συνεδρία και δες αν το Reset Your Future είναι για σένα.
            </p>
            <button class="btn-cta btn-cta-large">
                Κλείσε δωρεάν συνεδρία 20'
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14"></path>
                    <path d="m12 5 7 7-7 7"></path>
                </svg>
            </button>
        </div>
    </div>
</section>

<!-- Footer -->
<footer class="landing-footer">
    <div class="container">
        <div class="footer-content">
            <div class="footer-brand">
                <span class="footer-logo">Reset Your Future</span>
            </div>
            <div class="footer-author">
                <p class="footer-name">Γεώργιος Κόκκαλης</p>
                <p class="footer-role">Σύμβουλος Επαγγελματικού Προσανατολισμού</p>
            </div>
            <div class="footer-social">
                <a href="#" class="social-link" aria-label="YouTube">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"></path>
                        <path d="m10 15 5-3-5-3z"></path>
                    </svg>
                </a>
                <a href="@InstagramUrl" class="social-link" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
                        <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                        <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
                    </svg>
                </a>
            </div>
        </div>
        <div class="footer-bottom">
            <p>© 2026 Reset Your Future</p>
        </div>
    </div>
</footer>


@code {
    private string InstagramUrl => Configuration["Social:Instagram"] ?? "https://instagram.com/yourprofile";
}
