@page "/assessments"
@attribute [Authorize(Roles = "Student")]

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Available Assessments</h3>
    <a href="/assessments/mine" class="btn btn-outline-primary">📋 My Submissions</a>
</div>

<div class="row">
    @if (assessments == null)
    {
        <p>Loading...</p>
    }
    else if (assessments.Count == 0)
    {
        <p>No assessments available at this time.</p>
    }
    else
    {
        @foreach (var assessment in assessments)
        {
            <div class="col-md-6 mb-3">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">@assessment.Title</h5>
                        <p class="card-text">@assessment.Description</p>
                        <button class="btn btn-primary" @onclick="() => StartAssessment(assessment.Id)">Start</button>
                    </div>
                </div>
            </div>
        }
    }
</div>

