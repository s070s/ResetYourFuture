@page "/admin/courses/{CourseId:guid}"
@page "/admin/courses/new"
@using ResetYourFuture.Client.Shared
@attribute [Authorize(Roles = "Admin")]

<PageTitle>@(IsNew ? "Create Course" : "Edit Course")</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@(IsNew ? "Create Course" : "Edit Course")</h2>
    <button class="btn btn-secondary" @onclick="Cancel">← Back to Courses</button>
</div>

@if (!IsNew && course == null && string.IsNullOrEmpty(message))
{
    <p>Loading...</p>
}
else
{
    @* ── Course Details ── *@
    <div class="card mb-4">
        <div class="card-header">Course Details</div>
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label">Title</label>
                <input class="form-control" @bind="courseTitle" />
            </div>

            <div class="mb-3">
                <label class="form-label">Description</label>
                <QuillEditor @ref="descriptionEditor" Content="@courseDescription" MinHeight="150px" />
            </div>

            <button class="btn btn-primary" @onclick="SaveCourse" disabled="@isSaving">
                @(isSaving ? "Saving..." : "Save Course")
            </button>
        </div>
    </div>

    @if (IsNew)
    {
        <div class="alert alert-secondary mt-3">
            <i class="bi bi-info-circle"></i>
            Save the course first, then you can add <strong>Modules</strong>, <strong>Lessons</strong> (with the WYSIWYG editor, videos, PDFs), preview the course structure, and publish it.
        </div>
    }

    @if (!IsNew && course != null)
    {
        @* ── Modules & Lessons ── *@
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Modules &amp; Lessons</span>
                <button class="btn btn-sm btn-success" @onclick="ShowAddModule">+ Add Module</button>
            </div>
            <div class="card-body">
                @if (modules == null)
                {
                    <p>Loading modules...</p>
                }
                else if (modules.Count == 0)
                {
                    <p class="text-muted">No modules yet. Add one to get started.</p>
                }
                else
                {
                    @foreach (var module in modules.OrderBy(m => m.SortOrder))
                    {
                        var moduleLessons = lessonsMap.GetValueOrDefault(module.Id);
                        var isExpanded = expandedModules.Contains(module.Id);
                        <div class="card mb-2" @key="module.Id">
                            <div class="card-header d-flex justify-content-between align-items-center"
                                 style="cursor: pointer;" @onclick="() => ToggleModule(module.Id)">
                                <div>
                                    <span class="fw-semibold">@module.Title</span>
                                    <span class="badge bg-secondary ms-2">@module.LessonCount lesson(s)</span>
                                    <span class="badge bg-light text-dark ms-1">Order: @module.SortOrder</span>
                                </div>
                                <span>@(isExpanded ? "▲" : "▼")</span>
                            </div>
                            @if (isExpanded)
                            {
                                <div class="card-body">
                                    <div class="d-flex gap-2 mb-3">
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => ShowEditModule(module)">
                                            <i class="bi bi-pencil"></i> Edit Module
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteModule(module.Id)">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                        <button class="btn btn-sm btn-success" @onclick="() => ShowAddLesson(module.Id)">
                                            + Add Lesson
                                        </button>
                                    </div>
                                    @if (!string.IsNullOrEmpty(module.Description))
                                    {
                                        <p class="text-muted small mb-3">@module.Description</p>
                                    }

                                    @* Inline lessons list *@
                                    @if (moduleLessons == null)
                                    {
                                        <p class="text-muted small">Loading lessons...</p>
                                    }
                                    else if (moduleLessons.Count == 0)
                                    {
                                        <p class="text-muted small">No lessons in this module.</p>
                                    }
                                    else
                                    {
                                        <table class="table table-sm table-hover mb-0">
                                            <thead class="table-light">
                                                <tr>
                                                    <th style="width:40px">#</th>
                                                    <th>Title</th>
                                                    <th style="width:80px">Type</th>
                                                    <th style="width:70px">Mins</th>
                                                    <th style="width:80px">Status</th>
                                                    <th style="width:120px">Actions</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var lesson in moduleLessons.OrderBy(l => l.SortOrder))
                                                {
                                                    <tr @key="lesson.Id">
                                                        <td>@lesson.SortOrder</td>
                                                        <td>@lesson.Title</td>
                                                        <td>
                                                            @if (!string.IsNullOrEmpty(lesson.VideoPath))
                                                            {
                                                                <span class="badge bg-info">Video</span>
                                                            }
                                                            else if (!string.IsNullOrEmpty(lesson.PdfPath))
                                                            {
                                                                <span class="badge bg-warning text-dark">PDF</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="badge bg-light text-dark">Text</span>
                                                            }
                                                        </td>
                                                        <td>@(lesson.DurationMinutes?.ToString() ?? "—")</td>
                                                        <td>
                                                            <span class="badge @(lesson.IsPublished ? "bg-success" : "bg-secondary")">
                                                                @(lesson.IsPublished ? "Live" : "Draft")
                                                            </span>
                                                        </td>
                                                        <td>
                                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => ShowEditLesson(lesson)">Edit</button>
                                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteLesson(lesson.Id, module.Id)">✕</button>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    }
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        </div>

        @* ── Course Structure Preview ── *@
        <div class="card mb-4">
            <div class="card-header">Course Structure Preview</div>
            <div class="card-body">
                <pre class="bg-light p-3 rounded" style="max-height: 400px; overflow-y: auto; font-size: 0.85rem;">@GenerateCoursePreviewJson()</pre>
            </div>
        </div>

        @* ── Publish ── *@
        <div class="card mb-4">
            <div class="card-header">Publish</div>
            <div class="card-body d-flex align-items-center gap-2">
                <span class="badge @(course.IsPublished ? "bg-success" : "bg-secondary")">
                    @(course.IsPublished ? "Published" : "Draft")
                </span>
                @if (!course.IsPublished)
                {
                    <button class="btn btn-success" @onclick="PublishCourse">Publish Course</button>
                }
                else
                {
                    <button class="btn btn-warning" @onclick="UnpublishCourse">Unpublish Course</button>
                }
            </div>
        </div>
    }
}

@* ── Module Create/Edit Modal ── *@
@if (showModuleModal)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editingModuleId == null ? "Add Module" : "Edit Module")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModuleModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Title</label>
                        <input class="form-control" @bind="moduleTitle" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" @bind="moduleDescription" rows="3"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Sort Order</label>
                        <input type="number" class="form-control" @bind="moduleSortOrder" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-primary" @onclick="SaveModule">Save</button>
                    <button class="btn btn-secondary" @onclick="CloseModuleModal">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@* ── Lesson Create/Edit Modal ── *@
@if (showLessonModal)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editingLessonId == null ? "Add Lesson" : "Edit Lesson")</h5>
                    <button type="button" class="btn-close" @onclick="CloseLessonModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Title</label>
                            <input class="form-control" @bind="lessonTitle" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Sort Order</label>
                            <input type="number" class="form-control" @bind="lessonSortOrder" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Duration (minutes)</label>
                            <input type="number" class="form-control" @bind="lessonDuration" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Content</label>
                        <QuillEditor @ref="lessonContentEditor" Content="@lessonContent" MinHeight="300px" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Video URL (YouTube embed or direct link)</label>
                        <input class="form-control" @bind="lessonVideoUrl" placeholder="https://www.youtube.com/embed/..." />
                        <small class="text-muted">Paste a YouTube embed URL or direct video link. This takes priority over uploaded files and text content.</small>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Upload PDF</label>
                            <InputFile class="form-control" OnChange="OnPdfSelected" accept=".pdf" />
                            @if (!string.IsNullOrEmpty(lessonPdfPath))
                            {
                                <small class="text-success">Current: @lessonPdfPath</small>
                            }
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Upload Video File</label>
                            <InputFile class="form-control" OnChange="OnVideoSelected" accept="video/*" />
                            @if (!string.IsNullOrEmpty(lessonVideoFilePath))
                            {
                                <small class="text-success">Current: @lessonVideoFilePath</small>
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-primary" @onclick="SaveLesson" disabled="@isLessonSaving">
                        @(isLessonSaving ? "Saving..." : "Save Lesson")
                    </button>
                    <button class="btn btn-secondary" @onclick="CloseLessonModal">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-info alert-dismissible mt-3">
        @message
        <button type="button" class="btn-close" @onclick="() => message = string.Empty"></button>
    </div>
}

