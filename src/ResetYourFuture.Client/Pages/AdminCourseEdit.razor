@page "/admin/courses/{CourseId:guid}"
@page "/admin/courses/new"
@using ResetYourFuture.Client.Shared
@attribute [Authorize(Roles = "Admin")]

<PageTitle>@(IsNew ? AdminRes.CreateCourse : AdminRes.EditCourse)</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@(IsNew ? AdminRes.CreateCourse : AdminRes.EditCourse)</h2>
    <button class="btn btn-secondary" @onclick="Cancel">@AdminRes.BackToCourses</button>
</div>

@if (!IsNew && course == null && string.IsNullOrEmpty(message))
{
    <p>@AdminRes.Loading</p>
}
else
{
    @* ── Course Details ── *@
    <FormCardSection Title="@AdminRes.CourseDetails">
        <ChildContent>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">@AdminRes.FieldTitle (EN)</label>
                    <input class="form-control" @bind="courseTitleEn" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">@AdminRes.FieldTitle (EL)</label>
                    <input class="form-control" @bind="courseTitleEl" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">@AdminRes.FieldDescription (EN)</label>
                <QuillEditor @ref="descriptionEditorEn" Content="@courseDescriptionEn" MinHeight="150px" />
            </div>

            <div class="mb-3">
                <label class="form-label">@AdminRes.FieldDescription (EL)</label>
                <QuillEditor @ref="descriptionEditorEl" Content="@courseDescriptionEl" MinHeight="150px" />
            </div>

            <SaveCancelBar SaveLabel="@AdminRes.SaveCourse"
                           SavingLabel="@AdminRes.Saving"
                           IsSaving="isSaving"
                           OnSave="SaveCourse" />
        </ChildContent>
    </FormCardSection>

    @if (IsNew)
    {
        <div class="alert alert-secondary mt-3">
            <i class="bi bi-info-circle"></i>
            @((MarkupString)AdminRes.SaveCourseFirstHint)
        </div>
    }

    @if (!IsNew && course != null)
    {
        @* ── Modules & Lessons ── *@
        <FormCardSection Title="@AdminRes.ModulesAndLessons">
            <HeaderActions>
                <button class="btn btn-sm btn-success" @onclick="ShowAddModule">@AdminRes.AddModule</button>
            </HeaderActions>
            <ChildContent>
                @if (modules == null)
                {
                    <p>@AdminRes.LoadingModules</p>
                }
                else if (modules.Count == 0)
                {
                    <p class="text-light-muted">@AdminRes.NoModules</p>
                }
                else
                {
                    @foreach (var module in modules)
                    {
                        var moduleLessons = lessonsMap.GetValueOrDefault(module.Id);
                        var isExpanded = expandedModules.Contains(module.Id);
                        <div class="card mb-2" @key="module.Id">
                            <div class="card-header d-flex justify-content-between align-items-center"
                                 style="cursor: pointer;" @onclick="() => ToggleModule(module.Id)">
                                <div>
                                    <span class="fw-semibold">@module.TitleEn</span>
                                    <span class="badge bg-secondary ms-2">@string.Format(AdminRes.LessonsCountFormat, module.LessonCount)</span>
                                    <span class="badge bg-light text-dark ms-1">@string.Format(AdminRes.OrderFormat, module.SortOrder)</span>
                                </div>
                                <span>@(isExpanded ? "▲" : "▼")</span>
                            </div>
                            @if (isExpanded)
                            {
                                <div class="card-body">
                                    <div class="d-flex gap-2 mb-3">
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => ShowEditModule(module)">
                                            <i class="bi bi-pencil"></i> @AdminRes.EditModule
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteModule(module.Id)">
                                            <i class="bi bi-trash"></i> @AdminRes.Delete
                                        </button>
                                        <button class="btn btn-sm btn-success" @onclick="() => ShowAddLesson(module.Id)">
                                            @AdminRes.AddLesson
                                        </button>
                                    </div>
                                    @if (!string.IsNullOrEmpty(module.DescriptionEn))
                                    {
                                        <p class="text-light-muted small mb-3">@module.DescriptionEn</p>
                                    }

                                    @* Inline lessons list *@
                                    @if (moduleLessons == null)
                                    {
                                        <p class="text-light-muted small">@AdminRes.LoadingLessons</p>
                                    }
                                    else if (moduleLessons.Count == 0)
                                    {
                                        <p class="text-light-muted small">@AdminRes.NoLessons</p>
                                    }
                                    else
                                    {
                                        <table class="table table-sm table-hover mb-0">
                                            <thead class="table-light">
                                                <tr>
                                                    <th style="width:40px">#</th>
                                                    <th>@AdminRes.FieldTitle</th>
                                                    <th style="width:80px">@AdminRes.FieldType</th>
                                                    <th style="width:70px">@AdminRes.ColMins</th>
                                                    <th style="width:80px">@AdminRes.ColStatus</th>
                                                    <th style="width:120px">@AdminRes.ColActions</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var lesson in moduleLessons)
                                                {
                                                    <tr @key="lesson.Id">
                                                        <td>@lesson.SortOrder</td>
                                                        <td>@lesson.TitleEn</td>
                                                        <td>
                                                            @if (!string.IsNullOrEmpty(lesson.VideoPath))
                                                            {
                                                                <span class="badge bg-info">@AdminRes.LessonTypeVideo</span>
                                                            }
                                                            else if (!string.IsNullOrEmpty(lesson.PdfPath))
                                                            {
                                                                <span class="badge bg-warning text-dark">@AdminRes.LessonTypePdf</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="badge bg-light text-dark">@AdminRes.LessonTypeText</span>
                                                            }
                                                        </td>
                                                        <td>@(lesson.DurationMinutes?.ToString() ?? "—")</td>
                                                        <td>
                                                            <StatusBadge IsActive="lesson.IsPublished"
                                                                         ActiveText="@AdminRes.StatusLive"
                                                                         InactiveText="@AdminRes.StatusDraft" />
                                                        </td>
                                                        <td>
                                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => ShowEditLesson(lesson)">@AdminRes.Edit</button>
                                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteLesson(lesson.Id, module.Id)">✕</button>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    }
                                </div>
                            }
                        </div>
                    }
                }
            </ChildContent>
        </FormCardSection>

        @* ── Publish ── *@
        <FormCardSection Title="@AdminRes.Publish">
            <ChildContent>
                <div class="d-flex align-items-center gap-2">
                    <StatusBadge IsActive="course.IsPublished"
                                 ActiveText="@AdminRes.StatusPublished"
                                 InactiveText="@AdminRes.StatusDraft" />
                    @if (!course.IsPublished)
                    {
                        <button class="btn btn-success" @onclick="PublishCourse">@AdminRes.PublishCourse</button>
                    }
                    else
                    {
                        <button class="btn btn-warning" @onclick="UnpublishCourse">@AdminRes.UnpublishCourse</button>
                    }
                </div>
            </ChildContent>
        </FormCardSection>
    }
}

@* ── Module Create/Edit Modal ── *@
<FormModal IsVisible="showModuleModal"
           Title="@(editingModuleId == null ? AdminRes.AddModule : AdminRes.EditModule)"
           OnClose="CloseModuleModal">
    <Body>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">@AdminRes.FieldTitle (EN)</label>
                <input class="form-control" @bind="moduleTitleEn" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">@AdminRes.FieldTitle (EL)</label>
                <input class="form-control" @bind="moduleTitleEl" />
            </div>
        </div>
        <div class="mb-3">
            <label class="form-label">@AdminRes.FieldDescription (EN)</label>
            <textarea class="form-control" @bind="moduleDescriptionEn" rows="3"></textarea>
        </div>
        <div class="mb-3">
            <label class="form-label">@AdminRes.FieldDescription (EL)</label>
            <textarea class="form-control" @bind="moduleDescriptionEl" rows="3"></textarea>
        </div>
        <div class="mb-3">
            <label class="form-label">@AdminRes.SortOrder</label>
            <input type="number" class="form-control" @bind="moduleSortOrder" />
        </div>
    </Body>
    <Footer>
        <button class="btn btn-primary" @onclick="SaveModule">@AdminRes.Save</button>
        <button class="btn btn-secondary" @onclick="CloseModuleModal">@AdminRes.Cancel</button>
    </Footer>
</FormModal>

@* ── Lesson Create/Edit Modal ── *@
<FormModal IsVisible="showLessonModal"
           Title="@(editingLessonId == null ? AdminRes.AddLesson : AdminRes.EditLesson)"
           Size="modal-xl"
           OnClose="CloseLessonModal">
    <Body>
        <div class="row">
            <div class="col-md-3 mb-3">
                <label class="form-label">@AdminRes.FieldTitle (EN)</label>
                <input class="form-control" @bind="lessonTitleEn" />
            </div>
            <div class="col-md-3 mb-3">
                <label class="form-label">@AdminRes.FieldTitle (EL)</label>
                <input class="form-control" @bind="lessonTitleEl" />
            </div>
            <div class="col-md-3 mb-3">
                <label class="form-label">@AdminRes.SortOrder</label>
                <input type="number" class="form-control" @bind="lessonSortOrder" />
            </div>
            <div class="col-md-3 mb-3">
                <label class="form-label">@AdminRes.DurationMinutes</label>
                <input type="number" class="form-control" @bind="lessonDuration" />
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">@AdminRes.FieldContent (EN)</label>
            <QuillEditor @ref="lessonContentEditorEn" Content="@lessonContentEn" MinHeight="300px" />
        </div>

        <div class="mb-3">
            <label class="form-label">@AdminRes.FieldContent (EL)</label>
            <QuillEditor @ref="lessonContentEditorEl" Content="@lessonContentEl" MinHeight="300px" />
        </div>

        <div class="mb-3">
            <label class="form-label">@AdminRes.VideoUrlLabel</label>
            <input class="form-control" @bind="lessonVideoUrl" placeholder="https://www.youtube.com/embed/..." />
            <small class="text-light-muted">@AdminRes.VideoUrlHint</small>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">@AdminRes.UploadPdf</label>
                <InputFile class="form-control" OnChange="OnPdfSelected" accept=".pdf" />
                @if (!string.IsNullOrEmpty(lessonPdfPath))
                {
                    <small class="text-success">@AdminRes.Current @lessonPdfPath</small>
                }
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">@AdminRes.UploadVideo</label>
                <InputFile class="form-control" OnChange="OnVideoSelected" accept="video/*" />
                @if (!string.IsNullOrEmpty(lessonVideoFilePath))
                {
                    <small class="text-success">@AdminRes.Current @lessonVideoFilePath</small>
                }
            </div>
        </div>
    </Body>
    <Footer>
        <button class="btn btn-primary" @onclick="SaveLesson" disabled="@isLessonSaving">
            @(isLessonSaving ? AdminRes.Saving : AdminRes.SaveLesson)
        </button>
        <button class="btn btn-secondary" @onclick="CloseLessonModal">@AdminRes.Cancel</button>
    </Footer>
</FormModal>

<ConfirmModal IsVisible="@(_pendingDeleteModuleId.HasValue || _pendingDeleteLessonId.HasValue)"
              Title="Confirm"
              Message="@_pendingDeleteMessage"
              OnConfirm="ExecuteDeleteAsync"
              OnCancel="CancelPendingDelete" />

<DismissibleAlert Message="@message" OnDismiss="@(() => message = string.Empty)" />

