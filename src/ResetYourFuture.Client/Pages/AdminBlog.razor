@page "/admin/blog"
@attribute [Authorize(Roles = "Admin")]
@using ResetYourFuture.Client.Shared.Components.Data

<PageTitle>Blog Articles</PageTitle>

<div class="admin-container">
    <h2>Blog Articles</h2>

    <div class="d-flex gap-2 mb-3">
        <input type="text" class="form-control" placeholder="Search by title, slug or author..."
               value="@searchTerm" @oninput="OnSearchInput" />
        <button class="btn btn-primary text-nowrap" @onclick="NewArticle">New Article</button>
    </div>

    <AuthorizeView Roles="Admin">
        <Authorized>
            @if (pagedResult == null)
            {
                <p>@AdminRes.Loading</p>
            }
            else if (!pagedResult.Items.Any())
            {
                <p>No blog articles found.</p>
            }
            else
            {
                <VirtualizedTable Items="pagedResult.Items" TItem="AdminBlogArticleDto">
                    <HeaderRow>
                        <tr>
                            <th>Title</th>
                            <th>Slug</th>
                            <th>@AdminRes.ColStatus</th>
                            <th>Published At</th>
                            <th>@AdminRes.ColActions</th>
                        </tr>
                    </HeaderRow>
                    <RowTemplate Context="article">
                        <tr @key="article.Id">
                            <td data-label="Title">@article.TitleEn</td>
                            <td data-label="Slug"><code>@article.Slug</code></td>
                            <td data-label="@AdminRes.ColStatus">
                                <StatusBadge IsActive="article.IsPublished"
                                             ActiveText="@AdminRes.StatusPublished"
                                             InactiveText="@AdminRes.StatusDraft" />
                            </td>
                            <td data-label="Published">@(article.PublishedAt?.ToString("dd MMM yyyy") ?? "—")</td>
                            <td data-label="Actions">
                                <button class="btn btn-sm btn-primary me-1" @onclick="() => EditArticle(article.Id)">@AdminRes.Edit</button>
                                @if (article.IsPublished)
                                {
                                    <button class="btn btn-sm btn-warning me-1" @onclick="() => TogglePublish(article)">@AdminRes.Unpublish</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-success me-1" @onclick="() => TogglePublish(article)">@AdminRes.Publish</button>
                                }
                                @if (confirmDeleteId == article.Id)
                                {
                                    <button class="btn btn-sm btn-danger me-1" @onclick="() => DeleteArticle(article.Id)">@AdminRes.ConfirmDelete</button>
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => confirmDeleteId = null">@AdminRes.Cancel</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => confirmDeleteId = article.Id">@AdminRes.Delete</button>
                                }
                            </td>
                        </tr>
                    </RowTemplate>
                </VirtualizedTable>

                <AdminPaginationToolbar CurrentPage="pagedResult.Page"
                                        TotalPages="pagedResult.TotalPages"
                                        TotalCount="pagedResult.TotalCount"
                                        PageSize="pagedResult.PageSize"
                                        HasPreviousPage="pagedResult.HasPreviousPage"
                                        HasNextPage="pagedResult.HasNextPage"
                                        PageSizeOptions="PageSizeOptions"
                                        ItemLabel="articles"
                                        OnPageSizeChanged="OnPageSizeChanged"
                                        OnPreviousPage="PreviousPage"
                                        OnNextPage="NextPage" />
            }

            <DismissibleAlert Message="@message" Dismissible="false" OnDismiss="@(() => message = string.Empty)" />
        </Authorized>
        <NotAuthorized>
            <div class="alert alert-danger">@AdminRes.AccessDenied</div>
        </NotAuthorized>
    </AuthorizeView>
</div>
