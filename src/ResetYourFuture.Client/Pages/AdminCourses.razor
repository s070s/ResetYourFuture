@page "/admin/courses"
@attribute [Authorize(Roles = "Admin")]

<PageTitle>@AdminRes.CourseManagement</PageTitle>

<h2>@AdminRes.CourseManagement</h2>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="CreateCourse">@AdminRes.CreateNewCourse</button>
</div>

@if (courses == null)
{
    <p>@AdminRes.Loading</p>
}
else if (courses.Count == 0)
{
    <p>@AdminRes.NoCourses</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>@AdminRes.FieldTitle</th>
                    <th>@AdminRes.ColStatus</th>
                    <th>@AdminRes.ColEnrollments</th>
                    <th>@AdminRes.ColActions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var course in courses)
                {
                    <tr>
                        <td>@course.Title</td>
                        <td>
                            <span class="badge @(course.IsPublished ? "bg-success" : "bg-secondary")">
                                @(course.IsPublished ? AdminRes.StatusPublished : AdminRes.StatusDraft)
                            </span>
                        </td>
                        <td>@course.EnrollmentCount</td>
                        <td>
                            <button class="btn btn-sm btn-primary" @onclick="() => EditCourse(course.Id)">@AdminRes.Edit</button>
                            @if (course.IsPublished)
                            {
                                <button class="btn btn-sm btn-warning" @onclick="() => UnpublishCourse(course.Id)">@AdminRes.Unpublish</button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-success" @onclick="() => PublishCourse(course.Id)">@AdminRes.Publish</button>
                            }
                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteCourse(course.Id)">@AdminRes.Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-info alert-dismissible mt-3">
        @message
        <button type="button" class="btn-close" @onclick="() => message = string.Empty"></button>
    </div>
}

