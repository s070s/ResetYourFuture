@page "/admin/courses"
@attribute [Authorize(Roles = "Admin")]

<PageTitle>@AdminRes.CourseManagement</PageTitle>

<h2>@AdminRes.CourseManagement</h2>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="CreateCourse">@AdminRes.CreateNewCourse</button>
</div>

@if (pagedResult == null)
{
    <p>@AdminRes.Loading</p>
}
else if (!pagedResult.Items.Any())
{
    <p>@AdminRes.NoCourses</p>
}
else
{
    <VirtualizedTable Items="pagedResult.Items" TItem="AdminCourseDto">
        <HeaderRow>
            <tr>
                <th>@AdminRes.FieldTitle</th>
                <th>@AdminRes.ColStatus</th>
                <th>@AdminRes.ColEnrollments</th>
                <th>@AdminRes.ColActions</th>
            </tr>
        </HeaderRow>
        <RowTemplate Context="course">
            <tr @key="course.Id">
                <td>@course.TitleEn</td>
                <td>
                    <StatusBadge IsActive="course.IsPublished"
                                 ActiveText="@AdminRes.StatusPublished"
                                 InactiveText="@AdminRes.StatusDraft" />
                </td>
                <td>@course.EnrollmentCount</td>
                <td>
                    <button class="btn btn-sm btn-primary" @onclick="() => EditCourse(course.Id)">@AdminRes.Edit</button>
                    @if (course.IsPublished)
                    {
                        <button class="btn btn-sm btn-warning" @onclick="() => UnpublishCourse(course.Id)">@AdminRes.Unpublish</button>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-success" @onclick="() => PublishCourse(course.Id)">@AdminRes.Publish</button>
                    }
                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteCourse(course.Id)">@AdminRes.Delete</button>
                </td>
            </tr>
        </RowTemplate>
    </VirtualizedTable>

    <AdminPaginationToolbar CurrentPage="pagedResult.Page"
                            TotalPages="pagedResult.TotalPages"
                            TotalCount="pagedResult.TotalCount"
                            PageSize="pagedResult.PageSize"
                            HasPreviousPage="pagedResult.HasPreviousPage"
                            HasNextPage="pagedResult.HasNextPage"
                            PageSizeOptions="PageSizeOptions"
                            ItemLabel="courses"
                            OnPageSizeChanged="OnPageSizeChanged"
                            OnPreviousPage="PreviousPage"
                            OnNextPage="NextPage" />
}

<ConfirmModal IsVisible="@(_pendingDeleteId.HasValue)"
              Title="Confirm"
              Message="Are you sure you want to delete this course and all its modules/lessons?"
              OnConfirm="ExecuteDeleteAsync"
              OnCancel="@(() => _pendingDeleteId = null)" />

<DismissibleAlert Message="@message" OnDismiss="@(() => message = string.Empty)" />

