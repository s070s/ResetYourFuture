@page "/subscription/success"
@attribute [Authorize]

<PageTitle>Subscription Updated - Reset Your Future</PageTitle>

<div class="success-page">
    @if (_loading)
    {
        <p>Loading your subscription...</p>
    }
    else if (_status is not null)
    {
        <div class="success-card">
            <div class="success-icon">🎉</div>
            <h1>You're on the @_status.PlanName plan!</h1>
            <p>Your subscription is now active. Enjoy your new features.</p>

            <div class="plan-details">
                <p><strong>Plan:</strong> @_status.PlanName</p>
                <p><strong>Started:</strong> @_status.StartedAt.ToString("dd MMM yyyy")</p>
                @if (_status.ExpiresAt.HasValue)
                {
                    <p><strong>Renews:</strong> @_status.ExpiresAt.Value.ToString("dd MMM yyyy")</p>
                }
            </div>

            <div class="success-actions">
                <button class="btn btn-primary" @onclick="GoToCourses">Browse Courses</button>
                <button class="btn btn-secondary" @onclick="GoToPricing">View Plans</button>
            </div>
        </div>
    }
    else
    {
        <p>Unable to load subscription details.</p>
        <button class="btn btn-secondary" @onclick="GoToPricing">Back to Pricing</button>
    }
</div>
 

