@page "/admin/users"
@attribute [Authorize(Roles = "Admin")]

<PageTitle>@AdminRes.UserManagement</PageTitle>

<div class="admin-container">
    <h2>@AdminRes.UserManagement</h2>

    <div class="mb-3">
        <input type="text" class="form-control" placeholder="@AdminRes.SearchByEmailOrName"
               value="@searchTerm" @oninput="OnSearchInput" />
    </div>

    <AuthorizeView Roles="Admin">
        <Authorized>
            @if (pagedResult == null)
            {
                <p>@AdminRes.LoadingUsers</p>
            }
            else if (!pagedResult.Items.Any())
            {
                <p>@AdminRes.NoUsersFound</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>@AdminRes.ColEmail</th>
                                <th>@AdminRes.ColName</th>
                                <th>@AdminRes.ColEnabled</th>
                                <th>@AdminRes.ColRoles</th>
                                <th>@AdminRes.ColActions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in pagedResult.Items)
                            {
                                <tr @key="user.Id">
                                    <td>@user.Email</td>
                                    <td>@user.FirstName @user.LastName</td>
                                    <td>@(user.IsEnabled ? "✓" : "✗")</td>
                                    <td>@string.Join(", ", user.Roles)</td>
                                    <td>
                                        @if (user.Roles.Contains("Student"))
                                        {
                                            <button class="btn btn-sm btn-primary me-1" @onclick="() => ImpersonateUser(user.Id)">@AdminRes.LoginAs</button>
                                        }
                                        <button class="btn btn-sm btn-warning" @onclick="() => ForcePasswordReset(user.Id)">@AdminRes.ResetPassword</button>
                                        @if (user.IsEnabled)
                                        {
                                            <button class="btn btn-sm btn-secondary" @onclick="() => ToggleEnable(user.Id)">@AdminRes.DisableUser</button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-success" @onclick="() => ToggleEnable(user.Id)">@AdminRes.EnableUser</button>
                                        }
                                        @if (confirmDeleteId == user.Id)
                                        {
                                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteUser(user.Id)">@AdminRes.ConfirmDelete</button>
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => confirmDeleteId = null">@AdminRes.Cancel</button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-danger" @onclick="@(() => confirmDeleteId = user.Id)">@AdminRes.Delete</button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-3">
                    <small class="text-muted">
                        Showing @((pagedResult.Page - 1) * pagedResult.PageSize + 1)–@(Math.Min(pagedResult.Page * pagedResult.PageSize, pagedResult.TotalCount)) of @pagedResult.TotalCount users
                    </small>
                    <div class="d-flex align-items-center gap-2">
                        <label class="form-label mb-0 text-muted small">Rows:</label>
                        <select class="page-size-select" value="@pageSize" @onchange="OnPageSizeChanged">
                            @foreach (var opt in PageSizeOptions)
                            {
                                <option value="@opt">@opt</option>
                            }
                        </select>
                        <button class="btn btn-sm btn-outline-secondary"
                                @onclick="PreviousPage"
                                disabled="@(!pagedResult.HasPreviousPage)">‹ Prev</button>
                        <span class="small">Page @pagedResult.Page of @pagedResult.TotalPages</span>
                        <button class="btn btn-sm btn-outline-secondary"
                                @onclick="NextPage"
                                disabled="@(!pagedResult.HasNextPage)">Next ›</button>
                    </div>
                </div>
            }

            @if (!string.IsNullOrEmpty(message))
            {
                <div class="alert alert-info mt-3">@message</div>
            }
        </Authorized>
        <NotAuthorized>
            <div class="alert alert-danger">
                @AdminRes.AccessDenied
            </div>
        </NotAuthorized>
    </AuthorizeView>
</div>
