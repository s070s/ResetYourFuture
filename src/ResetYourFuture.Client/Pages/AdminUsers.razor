@page "/admin/users"
@attribute [Authorize(Roles = "Admin")]

<PageTitle>@AdminRes.UserManagement</PageTitle>

<div class="admin-container">
    <h2>@AdminRes.UserManagement</h2>

    <div class="mb-3">
        <input type="text" class="form-control" placeholder="@AdminRes.SearchByEmailOrName"
               value="@searchTerm" @oninput="OnSearchInput" />
    </div>

    <AuthorizeView Roles="Admin">
        <Authorized>
            @if (pagedResult == null)
            {
                <p>@AdminRes.LoadingUsers</p>
            }
            else if (!pagedResult.Items.Any())
            {
                <p>@AdminRes.NoUsersFound</p>
            }
            else
            {
                <VirtualizedTable Items="pagedResult.Items" TItem="AdminUserDto">
                    <HeaderRow>
                        <tr>
                            <th>@AdminRes.ColEmail</th>
                            <th>@AdminRes.ColName</th>
                            <th>@AdminRes.ColEnabled</th>
                            <th>@AdminRes.ColRoles</th>
                            <th>@AdminRes.ColActions</th>
                        </tr>
                    </HeaderRow>
                    <RowTemplate Context="user">
                        <tr @key="user.Id">
                            <td>@user.Email</td>
                            <td>@user.FirstName @user.LastName</td>
                            <td>@(user.IsEnabled ? "✓" : "✗")</td>
                            <td>@string.Join(", ", user.Roles)</td>
                            <td>
                                @if (user.Roles.Contains("Student"))
                                {
                                    <button class="btn btn-sm btn-primary me-1" @onclick="() => ImpersonateUser(user.Id)">@AdminRes.LoginAs</button>
                                }
                                <button class="btn btn-sm btn-warning" @onclick="() => ForcePasswordReset(user.Id)">@AdminRes.ResetPassword</button>
                                @if (user.IsEnabled)
                                {
                                    <button class="btn btn-sm btn-secondary" @onclick="() => ToggleEnable(user.Id)">@AdminRes.DisableUser</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-success" @onclick="() => ToggleEnable(user.Id)">@AdminRes.EnableUser</button>
                                }
                                @if (confirmDeleteId == user.Id)
                                {
                                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteUser(user.Id)">@AdminRes.ConfirmDelete</button>
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => confirmDeleteId = null">@AdminRes.Cancel</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-danger" @onclick="@(() => confirmDeleteId = user.Id)">@AdminRes.Delete</button>
                                }
                            </td>
                        </tr>
                    </RowTemplate>
                </VirtualizedTable>

                <AdminPaginationToolbar CurrentPage="pagedResult.Page"
                                        TotalPages="pagedResult.TotalPages"
                                        TotalCount="pagedResult.TotalCount"
                                        PageSize="pagedResult.PageSize"
                                        HasPreviousPage="pagedResult.HasPreviousPage"
                                        HasNextPage="pagedResult.HasNextPage"
                                        PageSizeOptions="PageSizeOptions"
                                        ItemLabel="users"
                                        OnPageSizeChanged="OnPageSizeChanged"
                                        OnPreviousPage="PreviousPage"
                                        OnNextPage="NextPage" />
            }

            <DismissibleAlert Message="@message" Dismissible="false" OnDismiss="@(() => message = string.Empty)" />
        </Authorized>
        <NotAuthorized>
            <div class="alert alert-danger">
                @AdminRes.AccessDenied
            </div>
        </NotAuthorized>
    </AuthorizeView>
</div>
