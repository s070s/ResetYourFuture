@page "/lessons/{LessonId:guid}"
@attribute [Authorize]

<PageTitle>@(_lesson?.Title ?? LessonRes.LessonDefault) - Reset Your Future</PageTitle>

@if (_loading)
{
    <p>@LessonRes.LoadingLesson</p>
}
else if (_error is not null)
{
    <p class="text-danger">@_error</p>
    <button class="btn btn-secondary" @onclick="GoBack">@LessonRes.Back</button>
}
else if (_lesson is null)
{
    <p>@LessonRes.LessonNotFound</p>
    <button class="btn btn-secondary" @onclick="GoBack">@LessonRes.Back</button>
}
else
{
    <div class="lesson-container">
        <div class="lesson-nav-top">
            <button class="btn-link" @onclick="() => GoToCourse(_lesson.CourseId)">
                ← @_lesson.CourseTitle
            </button>
            <span class="breadcrumb-separator">/</span>
            <span class="module-name">@_lesson.ModuleTitle</span>
        </div>

        <h1>@_lesson.Title</h1>

        @if (_lesson.DurationMinutes.HasValue)
        {
            <p class="duration">⏱ @_lesson.DurationMinutes @LessonRes.Minutes</p>
        }

        <div class="lesson-content">
            @if (_lesson.ContentType == 2)
            {
                @* Video lesson *@
                <div class="video-container">
                    <iframe 
                        src="@ToEmbedUrl(_lesson.Content)" 
                        title="@_lesson.Title"
                        frameborder="0" 
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                        allowfullscreen>
                    </iframe>
                </div>
            }
            else
            {
                @* Text lesson - render HTML from WYSIWYG or markdown from seed data *@
                <div class="text-content">
                    @((MarkupString)RenderContent(_lesson.Content ?? ""))
                </div>
            }
        </div>

        <div class="lesson-actions">
            @if (!_lesson.IsCompleted)
            {
                <button class="btn btn-success" @onclick="MarkComplete" disabled="@_completing">
                    @(_completing ? LessonRes.Saving : LessonRes.MarkAsComplete)
                </button>
            }
            else
            {
                <span class="completed-indicator">@LessonRes.CompletedIndicator</span>
            }

            @if (_completionResult is not null)
            {
                <div class="progress-update">
                    @string.Format(LessonRes.ProgressFormat, _completionResult.CompletedLessons, _completionResult.TotalLessons, _completionResult.ProgressPercent)
                    @if (_completionResult.CourseCompleted)
                    {
                        <span class="course-completed">@LessonRes.CourseCompleted</span>
                    }
                </div>
            }
        </div>

        <div class="lesson-navigation">
            @if (_lesson.PreviousLessonId.HasValue)
            {
                <button class="btn btn-secondary" @onclick="() => GoToLesson(_lesson.PreviousLessonId.Value)">
                    @LessonRes.PreviousLesson
                </button>
            }
            else
            {
                <span></span>
            }

            @if (_lesson.NextLessonId.HasValue)
            {
                <button class="btn btn-primary" @onclick="() => GoToLesson(_lesson.NextLessonId.Value)">
                    @LessonRes.NextLesson
                </button>
            }
            else
            {
                <button class="btn btn-secondary" @onclick="() => GoToCourse(_lesson.CourseId)">
                    @LessonRes.BackToCourse
                </button>
            }
        </div>
    </div>
}
 

