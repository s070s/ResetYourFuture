@page "/register"
@implements IDisposable

<PageTitle>@GlobalRes.Label_Register</PageTitle>

<div class="auth-container">
    <h2>@GlobalRes.Label_CreateAccount</h2>




    @if (Env.IsDevelopment())
    {
            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="alert alert-success" style="overflow-wrap: anywhere;">
                    @successMessage
                    <div class="mt-3">
                    <button class="btn btn-sm btn-warning" @onclick="DevConfirmEmail">@GlobalRes.Label_ConfirmEmail</button>
                    </div>
                </div>
            }        
    }
    else
    {
        <div>@SuccessMessagesRes.RegistrationSuccess</div>
    }

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    @if (errors.Any())
    {
        <div class="alert alert-danger">
            <ul class="mb-0">
                @foreach (var error in errors)
                {
                    <li>@error</li>
                }
            </ul>
        </div>
    }

    <EditForm EditContext="editContext" OnValidSubmit="HandleRegister">
        <DataAnnotationsValidator />

        <div class="row">
            <div class="col-md-6 mb-3">
                <label for="firstName" class="form-label">@GlobalRes.Label_Info_FirstName</label>
                <InputText id="firstName" class="form-control" @bind-Value="registerRequest.FirstName" />
                <ValidationMessage For="@(() => registerRequest.FirstName)" />
            </div>
            <div class="col-md-6 mb-3">
                <label for="lastName" class="form-label">@GlobalRes.Label_Info_LastName</label>
                <InputText id="lastName" class="form-control" @bind-Value="registerRequest.LastName" />
                <ValidationMessage For="@(() => registerRequest.LastName)" />
            </div>
        </div>

        <div class="mb-3">
            <label for="email" class="form-label">@GlobalRes.Label_Info_Email</label>
            <InputText id="email" class="form-control" @bind-Value="registerRequest.Email" />
            <ValidationMessage For="@(() => registerRequest.Email)" />
        </div>

        <div class="mb-3">
            <label for="dob" class="form-label">@GlobalRes.Label_Info_DateOfBirth</label>
            <InputDate id="dob" class="form-control" @bind-Value="registerRequest.DateOfBirth" />
        </div>

        <div class="mb-3">
            <label for="password" class="form-label">@GlobalRes.Label_Password @GlobalRes.Label_Minimum8Chars</label>
            <div class="input-group">
                <InputText id="password" type="@passwordInputType" class="form-control" @bind-Value="registerRequest.Password" />
                <button type="button" class="btn btn-password-toggle" @onclick="TogglePasswordVisibility" tabindex="-1">
                    <i class="@passwordIconClass"></i>
                </button>
            </div>
            <ValidationMessage For="@(() => registerRequest.Password)" />
        </div>

        <div class="mb-3">
            <label for="confirmPassword" class="form-label">@GlobalRes.Label_ConfirmPassword</label>
            <div class="input-group">
                <InputText id="confirmPassword" type="@confirmPasswordInputType" class="form-control" @bind-Value="registerRequest.ConfirmPassword" />
                <button type="button" class="btn btn-password-toggle" @onclick="ToggleConfirmPasswordVisibility" tabindex="-1">
                    <i class="@confirmPasswordIconClass"></i>
                </button>
            </div>
            <ValidationMessage For="@(() => registerRequest.ConfirmPassword)" />
        </div>

        <div class="mb-3 form-check">
            <InputCheckbox id="gdprConsent" class="form-check-input" @bind-Value="registerRequest.GdprConsent" />
            <label for="gdprConsent" class="form-check-label">
                @GlobalRes.Label_GdprConsent
            </label>
            <ValidationMessage For="@(() => registerRequest.GdprConsent)" />
        </div>

        <button type="submit" class="btn btn-primary" disabled="@isLoading">
            @if (isLoading) { <span>@GlobalRes.Label_Registering</span> } else { <span>@GlobalRes.Label_Register</span> }
        </button>
    </EditForm>

    <p class="mt-3">
        @GlobalRes.Label_AlreadyHaveAccount <a href="/login">@GlobalRes.Label_Login</a>
    </p>
</div>

