@* Renders the upgrade-prompt lock block for subscription-gated features. *@

<div class="upgrade-prompt">
    <div class="upgrade-icon">🔒</div>
    <h4>@PlanName Plan Required</h4>
    <p>@Description</p>
    <a href="@PricingPath" class="btn btn-primary">@UpgradeButtonText</a>
</div>

@code {
    [Parameter] public string PlanName { get; set; } = "Plus";
    [Parameter] public string FeatureName { get; set; } = "this feature";
    [Parameter] public string Description { get; set; } = "";
    [Parameter] public string PricingPath { get; set; } = "/pricing";
    [Parameter] public string UpgradeButtonText { get; set; } = "Upgrade Now";
}
