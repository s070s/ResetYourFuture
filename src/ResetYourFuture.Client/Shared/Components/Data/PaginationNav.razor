@* Renders a numbered pagination nav with prev/next buttons. Only renders when TotalPages > 1. *@

@if (TotalPages > 1)
{
    <div class="d-flex align-items-center gap-2" aria-label="@AriaLabel">
        <button class="btn btn-sm btn-outline-secondary"
                disabled="@(!HasPreviousPage)"
                @onclick="() => HandlePageChanged(CurrentPage - 1)">
            ‹ @PreviousLabel
        </button>
        <span class="small">Page @CurrentPage of @TotalPages</span>
        <button class="btn btn-sm btn-outline-secondary"
                disabled="@(!HasNextPage)"
                @onclick="() => HandlePageChanged(CurrentPage + 1)">
            @NextLabel ›
        </button>
    </div>
}

@code {
    [Parameter, EditorRequired] public int CurrentPage { get; set; }
    [Parameter, EditorRequired] public int TotalPages { get; set; }
    [Parameter, EditorRequired] public bool HasPreviousPage { get; set; }
    [Parameter, EditorRequired] public bool HasNextPage { get; set; }
    [Parameter] public string PreviousLabel { get; set; } = "Previous";
    [Parameter] public string NextLabel { get; set; } = "Next";
    [Parameter] public string AriaLabel { get; set; } = "Page navigation";
    [Parameter] public EventCallback<int> OnPageChanged { get; set; }

    private async Task HandlePageChanged(int page)
    {
        if (page < 1 || page > TotalPages)
            return;
        await OnPageChanged.InvokeAsync(page);
    }
}
